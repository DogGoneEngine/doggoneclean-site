---
// src/pages/track.astro
// The Dog Gone Tracker (pizza_tracker_client_loop): the client's live view
// of their visit at /track?t=<tracker_token>. The token is the key (an SMS
// recipient is not logged into anything); the page calls the anon
// tracker_status RPC, which returns only what the recipient should see.
// Six stages: scheduled, rolling, we're here (setting up), underway,
// coming back to your door, done. While rolling, the tracker-eta edge
// function serves a live drive ETA and the truck's position for the map.
// Links answer for the visit plus 7 days, then point at the portal.
// Look: Neural Expressive turned up (Paul 2026-06-10): gradient washes,
// glow, the wordmark with a trotting paw line, paw-print stage dots.
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="The Dog Gone Tracker | Dog Gone Clean"
  description="Follow your dog's visit live: rolling your way, we're here, underway, coming back to your door, done."
>
  <section class="trk-hero">
    <div class="trk-glow trk-glow--a" aria-hidden="true"></div>
    <div class="trk-glow trk-glow--b" aria-hidden="true"></div>
    <div class="container">
      <div class="trk-pawline" aria-hidden="true">
        <svg class="trk-pawline__paw" viewBox="0 0 24 24"><use href="#trk-paw" /></svg>
        <svg class="trk-pawline__paw" viewBox="0 0 24 24"><use href="#trk-paw" /></svg>
        <svg class="trk-pawline__paw" viewBox="0 0 24 24"><use href="#trk-paw" /></svg>
        <svg class="trk-pawline__paw" viewBox="0 0 24 24"><use href="#trk-paw" /></svg>
        <svg class="trk-pawline__paw" viewBox="0 0 24 24"><use href="#trk-paw" /></svg>
      </div>
      <p class="trk-wordmark">The <span class="grad">Dog Gone</span> Tracker</p>
      <h1 id="trk-title">Checking on <span class="grad">your visit...</span></h1>
      <p class="trk-sub" id="trk-sub"></p>

      <div class="trk-card" id="trk-card" hidden>
        <!-- specialist_named_not_promised: the visitor sees by name and face
             who is coming to their driveway. Today that is Paul, the sole
             operator; when routes get operators this reads from the route. -->
        <div class="trk-who">
          <img src="/photos/paul-specialist.jpg" width="56" height="56" alt="Your Hurricane Bath Operator with a client's dog in the trailer" />
          <div>
            <strong id="trk-who-name">Paul Nickerson</strong>
            <p id="trk-who-role">Owner and Hurricane Bath Operator. The one rolling up to your driveway.</p>
          </div>
        </div>

        <div class="trk-eta" id="trk-eta" hidden>
          <div class="trk-eta__big"><span id="trk-eta-min">--</span><small>min away</small></div>
          <p class="trk-eta__fresh" id="trk-eta-fresh">live</p>
          <div class="trk-map" id="trk-map" hidden></div>
        </div>

        <ol class="trk-steps" id="trk-steps">
          <li data-stage="scheduled"><span class="trk-paw"><svg viewBox="0 0 24 24"><use href="#trk-paw" /></svg></span><div><strong>Scheduled</strong><p>Your visit is on the books.</p></div></li>
          <li data-stage="on_the_way"><span class="trk-paw"><svg viewBox="0 0 24 24"><use href="#trk-paw" /></svg></span><div><strong>Rolling your way</strong><p>Dog Gone Clean is on the road to you.</p></div></li>
          <li data-stage="arrived"><span class="trk-paw"><svg viewBox="0 0 24 24"><use href="#trk-paw" /></svg></span><div><strong>We're here!</strong><p>Setting up in your driveway. We will be with you shortly.</p></div></li>
          <li data-stage="underway"><span class="trk-paw"><svg viewBox="0 0 24 24"><use href="#trk-paw" /></svg></span><div><strong>In the trailer</strong><p>Warm water, fresh towels, good company. The work is underway.</p></div></li>
          <li data-stage="returning"><span class="trk-paw"><svg viewBox="0 0 24 24"><use href="#trk-paw" /></svg></span><div><strong>Coming back to your door</strong><p>All finished. We are walking them back to you right now.</p></div></li>
          <li data-stage="done"><span class="trk-paw"><svg viewBox="0 0 24 24"><use href="#trk-paw" /></svg></span><div><strong>All done</strong><p>Clean, dry, and back to their day.</p></div></li>
        </ol>

        <button type="button" class="trk-sound" id="trk-sound" aria-pressed="false">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9" /><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0" /></svg>
          <span id="trk-sound-label">Chime when the status changes: off</span>
        </button>

        <p class="trk-block" id="trk-block"></p>
        <div class="trk-photos" id="trk-photos" hidden>
          <p class="trk-photos__label">Photos from this visit</p>
          <!-- The shareable moment: once a before and an after both exist,
               a clean side-by-side collage (thin white divider, nothing
               flowery) leads the strip. Tap to share or save. -->
          <div class="trk-collages" id="trk-collages" hidden></div>
          <div class="trk-photos__grid" id="trk-photos-grid"></div>
        </div>
      </div>

      <div class="trk-card trk-card--missing" id="trk-missing" hidden>
        <p id="trk-missing-text">We could not find a visit for this link. If it came in a text from
        us, tap it again or ask us to resend it.</p>
        <p><a href="/" id="trk-missing-link">Back to Dog Gone Clean</a></p>
      </div>

      <!-- Who is coming to your house: the full-size photo card. The header
           thumbnail says "a person named Paul"; this says "THIS person". -->
      <div class="trk-card trk-meet" id="trk-meet" hidden>
        <img id="trk-meet-img" src="/photos/og-cover.jpg" alt="Paul Nickerson, smiling, with a client's freshly bathed dog over his shoulder" />
        <div class="trk-meet__text">
          <p class="trk-meet__eyebrow">Who's coming to your door</p>
          <strong id="trk-meet-name">Paul Nickerson</strong>
          <p>Owner and Hurricane Bath Operator. Over 20 years of Ocala's dogs,
          one driveway at a time. Your dog is in good hands.</p>
        </div>
      </div>
    </div>

    <svg width="0" height="0" style="position:absolute" aria-hidden="true">
      <defs>
        <path id="trk-paw" d="M12 11.5c2.6 0 4.8 2 4.8 4.3 0 1.9-1.5 2.9-3.2 2.9-1 0-1.2-.35-1.6-.35s-.6.35-1.6.35c-1.7 0-3.2-1-3.2-2.9 0-2.4 2.2-4.3 4.8-4.3zM6.2 8.7c1 0 1.9.9 1.9 2.1S7.2 13 6.2 13s-1.9-1-1.9-2.2.8-2.1 1.9-2.1zm11.6 0c1 0 1.9.9 1.9 2.1S18.8 13 17.8 13s-1.9-1-1.9-2.2.8-2.1 1.9-2.1zM9.3 4.6c1.1 0 2 1 2 2.3s-.9 2.3-2 2.3-2-1-2-2.3.9-2.3 2-2.3zm5.4 0c1.1 0 2 1 2 2.3s-.9 2.3-2 2.3-2-1-2-2.3.9-2.3 2-2.3z" />
        <linearGradient id="trk-paw-grad" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#2563eb" />
          <stop offset="100%" stop-color="#22d3ee" />
        </linearGradient>
      </defs>
    </svg>
  </section>
</BaseLayout>

<style>
  .trk-hero {
    position: relative;
    overflow: hidden;
    padding: var(--space-3xl) 0 var(--space-3xl);
    text-align: center;
    min-height: 70vh;
  }
  .trk-glow {
    position: absolute;
    border-radius: 999px;
    filter: blur(70px);
    pointer-events: none;
  }
  .trk-glow--a {
    width: 480px; height: 480px;
    top: -180px; left: 50%;
    transform: translateX(-75%);
    background: radial-gradient(circle, rgba(37, 99, 235, 0.22), transparent 70%);
  }
  .trk-glow--b {
    width: 380px; height: 380px;
    top: 140px; right: -140px;
    background: radial-gradient(circle, rgba(34, 211, 238, 0.16), transparent 70%);
  }
  .container { position: relative; }

  /* The wordmark with a trotting paw line above it: left-right-left-right,
     each paw slightly rotated like a real track, fading in one after another
     on a slow loop. Gentle fluid motion, never frantic. */
  .trk-pawline {
    display: flex;
    justify-content: center;
    gap: 18px;
    margin-bottom: 2px;
  }
  .trk-pawline__paw {
    width: 17px;
    height: 17px;
    fill: var(--accent);
    opacity: 0.18;
    animation: trk-trot 3.6s ease-in-out infinite;
  }
  .trk-pawline__paw:nth-child(odd) { transform: rotate(-14deg) translateY(-3px); }
  .trk-pawline__paw:nth-child(even) { transform: rotate(14deg) translateY(3px); }
  .trk-pawline__paw:nth-child(1) { animation-delay: 0s; }
  .trk-pawline__paw:nth-child(2) { animation-delay: 0.35s; }
  .trk-pawline__paw:nth-child(3) { animation-delay: 0.7s; }
  .trk-pawline__paw:nth-child(4) { animation-delay: 1.05s; }
  .trk-pawline__paw:nth-child(5) { animation-delay: 1.4s; }
  @keyframes trk-trot {
    0%, 100% { opacity: 0.14; }
    18% { opacity: 0.85; }
    40% { opacity: 0.3; }
  }
  @media (prefers-reduced-motion: reduce) {
    .trk-pawline__paw, .trk-steps li.is-active .trk-paw { animation: none; }
  }

  .trk-wordmark {
    font-size: clamp(1.5rem, 5vw, 2.2rem);
    font-weight: 800;
    letter-spacing: -0.01em;
    margin: 0 0 var(--space-lg);
    color: var(--ink);
  }
  .trk-hero h1 {
    font-size: clamp(1.7rem, 5.5vw, 2.7rem);
    line-height: 1.12;
    margin: 0 0 var(--space-sm);
  }
  .trk-sub {
    color: var(--soft);
    margin: 0 auto var(--space-xl);
    max-width: 30rem;
  }
  .trk-card {
    max-width: 460px;
    margin: 0 auto;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    box-shadow: 0 18px 50px -18px rgba(37, 99, 235, 0.25);
    text-align: left;
  }
  .trk-who {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding-bottom: var(--space-lg);
    margin-bottom: var(--space-lg);
    border-bottom: 1px solid var(--line);
  }
  .trk-who img {
    width: 56px;
    height: 56px;
    border-radius: 999px;
    object-fit: cover;
    flex-shrink: 0;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.18);
  }
  .trk-who strong { color: var(--ink); display: block; }
  .trk-who p { margin: 2px 0 0; color: var(--soft); font-size: var(--text-sm); }

  /* Live ETA: the number is the headline while the truck is rolling. */
  .trk-eta {
    margin-bottom: var(--space-lg);
    padding: var(--space-lg);
    border-radius: var(--radius-md, 14px);
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.09), rgba(34, 211, 238, 0.09));
    border: 1px solid rgba(37, 99, 235, 0.18);
    text-align: center;
  }
  .trk-eta__big {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 8px;
    color: var(--ink);
  }
  .trk-eta__big span {
    font-size: clamp(2.6rem, 9vw, 3.4rem);
    font-weight: 800;
    line-height: 1;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .trk-eta__big small {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--soft);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .trk-eta__fresh {
    margin: 4px 0 0;
    font-size: var(--text-xs);
    color: var(--soft);
  }
  .trk-map {
    margin-top: var(--space-md);
    height: 220px;
    border-radius: 12px;
    overflow: hidden;
  }

  .trk-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .trk-steps li {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
    opacity: 0.36;
  }
  .trk-steps li.is-done { opacity: 0.72; }
  .trk-steps li.is-active { opacity: 1; }
  .trk-paw {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    margin-top: 1px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .trk-paw svg { width: 24px; height: 24px; fill: var(--line); }
  .trk-steps li.is-done .trk-paw svg { fill: var(--accent); }
  .trk-steps li.is-active .trk-paw svg {
    fill: url(#trk-paw-grad);
    filter: drop-shadow(0 0 7px rgba(37, 99, 235, 0.55));
  }
  .trk-steps li.is-active .trk-paw {
    animation: trk-pulse 2.4s ease-in-out infinite;
  }
  @keyframes trk-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.18); }
  }
  .trk-steps strong { display: block; color: var(--ink); }
  .trk-steps p { margin: 2px 0 0; color: var(--soft); font-size: var(--text-sm); }

  .trk-sound {
    margin-top: var(--space-lg);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--soft);
    font-size: var(--text-xs);
    font-weight: 600;
    cursor: pointer;
  }
  .trk-sound svg { width: 15px; height: 15px; }
  .trk-sound[aria-pressed="true"] {
    border-color: rgba(37, 99, 235, 0.45);
    color: var(--accent);
    background: rgba(37, 99, 235, 0.07);
  }

  .trk-block {
    margin: var(--space-xl) 0 0;
    padding-top: var(--space-lg);
    border-top: 1px solid var(--line);
    color: var(--soft);
    font-size: var(--text-sm);
  }
  .trk-card--missing { text-align: center; color: var(--soft); }

  .trk-meet {
    margin-top: var(--space-xl);
    padding: 0;
    overflow: hidden;
  }
  .trk-meet img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    display: block;
  }
  .trk-meet__text { padding: var(--space-lg) var(--space-xl) var(--space-xl); }
  .trk-meet__eyebrow {
    margin: 0 0 var(--space-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--accent);
  }
  .trk-meet strong { color: var(--ink); font-size: 1.1rem; }
  .trk-meet__text p:last-child { margin: 6px 0 0; color: var(--soft); font-size: var(--text-sm); }

  .trk-photos {
    margin-top: var(--space-lg);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--line);
  }
  .trk-photos__label {
    margin: 0 0 var(--space-sm);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .trk-collages {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }
  .trk-collages img {
    width: 100%;
    border-radius: 12px;
    display: block;
    cursor: pointer;
    box-shadow: var(--shadow-sm);
  }
  .trk-collages .trk-collage__hint {
    margin: 2px 0 0;
    font-size: var(--text-xs);
    color: var(--soft);
    text-align: center;
  }
  .trk-photos__grid {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }
  .trk-photos__grid a { position: relative; display: block; }
  .trk-photos__grid img {
    width: 96px;
    height: 96px;
    object-fit: cover;
    border-radius: 10px;
    display: block;
    box-shadow: var(--shadow-sm);
  }
  .trk-photos__grid span {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    font-size: 10px;
    text-align: center;
    background: rgba(12, 19, 34, 0.55);
    color: #fff;
    border-radius: 0 0 10px 10px;
    padding: 1px 0;
  }
</style>

<script>
  import { createClient } from '@supabase/supabase-js';
  import { SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY } from '../components/portal/supabase.js';
  import { loadGoogleMaps } from '../components/portal/maps.js';

  const STAGES = ['scheduled', 'on_the_way', 'arrived', 'underway', 'returning', 'done'];
  const token = new URLSearchParams(window.location.search).get('t') || '';

  const titleEl = document.getElementById('trk-title')!;
  const subEl = document.getElementById('trk-sub')!;
  const cardEl = document.getElementById('trk-card')!;
  const missingEl = document.getElementById('trk-missing')!;
  const missingTextEl = document.getElementById('trk-missing-text')!;
  const missingLinkEl = document.getElementById('trk-missing-link') as HTMLAnchorElement;
  const blockEl = document.getElementById('trk-block')!;
  const meetEl = document.getElementById('trk-meet')!;

  const dayFmt = new Intl.DateTimeFormat('en-US', { timeZone: 'America/New_York', weekday: 'long', month: 'long', day: 'numeric' });
  const timeFmt = new Intl.DateTimeFormat('en-US', { timeZone: 'America/New_York', hour: 'numeric', minute: '2-digit' });

  const client = createClient(SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY, {
    auth: { persistSession: false, autoRefreshToken: false, detectSessionInUrl: false },
  });

  function dogPhrase(dogs: string[]) {
    if (!dogs || dogs.length === 0) return 'your dog';
    if (dogs.length === 1) return dogs[0];
    if (dogs.length === 2) return `${dogs[0]} and ${dogs[1]}`;
    return `${dogs.slice(0, -1).join(', ')}, and ${dogs[dogs.length - 1]}`;
  }
  function cap(s: string) { return s.charAt(0).toUpperCase() + s.slice(1); }

  function headline(stage: string, dogs: string[]) {
    const d = cap(dogPhrase(dogs));
    // "Bandit and Bruno ARE done", "Dory IS done": the pack size picks the verb.
    const isAre = (dogs || []).length > 1 ? 'are' : 'is';
    switch (stage) {
      case 'on_the_way': return `${d}'s visit is rolling your way.`;
      case 'arrived': return `We're here! ${d} ${isAre} up soon.`;
      case 'underway': return `${d}'s visit is underway.`;
      case 'returning': return `${d} ${isAre} coming back to your door!`;
      case 'done': return `${d} ${isAre} done. Show someone.`;
      default: return `${d}'s visit is on the books.`;
    }
  }

  // ── Gentle chimes + vibration on stage changes ─────────────────────────
  // Off until the client taps the toggle once (browsers only allow sound
  // after a gesture on the page), then remembered on this device. Tones are
  // tiny Web Audio sketches, quiet and short: a roll-out hum, a doorbell for
  // the driveway, a soft plip for underway, a bright look-at-the-door run,
  // a wrap-up sparkle. Never longer than a second, never loud.
  let audioCtx: AudioContext | null = null;
  let soundOn = localStorage.getItem('dgc_trk_sound') === '1';
  const soundBtn = document.getElementById('trk-sound')!;
  const soundLabel = document.getElementById('trk-sound-label')!;

  function paintSound() {
    soundBtn.setAttribute('aria-pressed', soundOn ? 'true' : 'false');
    soundLabel.textContent = `Chime when the status changes: ${soundOn ? 'on' : 'off'}`;
  }
  function ensureAudio() {
    if (!audioCtx) {
      const AC = window.AudioContext || (window as any).webkitAudioContext;
      if (AC) audioCtx = new AC();
    }
    if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
    return audioCtx;
  }
  function tone(freq: number, at: number, dur: number, peak = 0.06) {
    const ctx = audioCtx;
    if (!ctx) return;
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.type = 'sine';
    osc.frequency.value = freq;
    gain.gain.setValueAtTime(0.0001, ctx.currentTime + at);
    gain.gain.exponentialRampToValueAtTime(peak, ctx.currentTime + at + 0.02);
    gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + at + dur);
    osc.connect(gain).connect(ctx.destination);
    osc.start(ctx.currentTime + at);
    osc.stop(ctx.currentTime + at + dur + 0.05);
  }
  const CHIMES: Record<string, () => void> = {
    on_the_way() { tone(659, 0, 0.35); tone(880, 0.18, 0.45); },
    arrived() { tone(659, 0, 0.5, 0.07); tone(523, 0.32, 0.7, 0.07); },             // the doorbell
    underway() { tone(784, 0, 0.3, 0.05); },
    returning() { tone(523, 0, 0.25); tone(659, 0.14, 0.25); tone(784, 0.28, 0.5); }, // look at the door
    done() { tone(784, 0, 0.25); tone(1047, 0.14, 0.6); },
  };
  const BUZZES: Record<string, number[]> = {
    on_the_way: [80],
    arrived: [120, 80, 120],
    underway: [50],
    returning: [120, 80, 120, 80, 160],
    done: [60, 40, 60],
  };
  function announce(stage: string) {
    if (!soundOn) return;
    if (ensureAudio() && CHIMES[stage]) CHIMES[stage]();
    if (navigator.vibrate && BUZZES[stage]) navigator.vibrate(BUZZES[stage]);
  }
  soundBtn.addEventListener('click', () => {
    soundOn = !soundOn;
    localStorage.setItem('dgc_trk_sound', soundOn ? '1' : '0');
    paintSound();
    if (soundOn && ensureAudio()) { tone(659, 0, 0.2, 0.04); tone(880, 0.1, 0.3, 0.04); }
  });
  paintSound();

  // ── Live ETA + the truck on a map (only while rolling) ────────────────
  const etaEl = document.getElementById('trk-eta')!;
  const etaMinEl = document.getElementById('trk-eta-min')!;
  const etaFreshEl = document.getElementById('trk-eta-fresh')!;
  const mapEl = document.getElementById('trk-map')!;
  let map: any = null;
  let truckMarker: any = null;
  let homeMarker: any = null;
  let mapFitted = false;
  let etaTimer: ReturnType<typeof setTimeout> | null = null;

  // The home marker is a paw print, not a generic red pin: this is the dog's
  // house. Same paw path as the stage dots, in the brand blue, white halo so
  // it reads on any map tile.
  const PAW_PATH = 'M12 11.5c2.6 0 4.8 2 4.8 4.3 0 1.9-1.5 2.9-3.2 2.9-1 0-1.2-.35-1.6-.35s-.6.35-1.6.35c-1.7 0-3.2-1-3.2-2.9 0-2.4 2.2-4.3 4.8-4.3zM6.2 8.7c1 0 1.9.9 1.9 2.1S7.2 13 6.2 13s-1.9-1-1.9-2.2.8-2.1 1.9-2.1zm11.6 0c1 0 1.9.9 1.9 2.1S18.8 13 17.8 13s-1.9-1-1.9-2.2.8-2.1 1.9-2.1zM9.3 4.6c1.1 0 2 1 2 2.3s-.9 2.3-2 2.3-2-1-2-2.3.9-2.3 2-2.3zm5.4 0c1.1 0 2 1 2 2.3s-.9 2.3-2 2.3-2-1-2-2.3.9-2.3 2-2.3z';
  const PAW_ICON_URL = 'data:image/svg+xml;charset=UTF-8,' + encodeURIComponent(
    `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="42" height="42">` +
    `<circle cx="12" cy="12" r="11" fill="#ffffff" opacity="0.9"/>` +
    `<path d="${PAW_PATH}" fill="#2563eb"/></svg>`,
  );

  async function ensureMap(op: { lat: number; lng: number }, dest: { lat: number; lng: number }) {
    try {
      const gm = await loadGoogleMaps();
      const { Map } = await gm.importLibrary('maps');
      const markerLib = await gm.importLibrary('marker');
      const MarkerCtor = markerLib.Marker || gm.Marker;
      if (!map) {
        mapEl.hidden = false;
        map = new Map(mapEl, {
          center: dest, zoom: 12,
          disableDefaultUI: true, zoomControl: false, clickableIcons: false,
          gestureHandling: 'cooperative',
        });
        homeMarker = new MarkerCtor({
          map, position: dest, title: 'Your home',
          icon: { url: PAW_ICON_URL, scaledSize: new gm.Size(42, 42), anchor: new gm.Point(21, 21) },
        });
        truckMarker = new MarkerCtor({
          map, position: op, title: 'Dog Gone Clean',
          // The truck is the brand: the shaking-dog mark on a round badge
          // (public/tracker-dog-marker.png, cut from the logo), not a generic
          // blue dot. The home stays the paw print.
          icon: {
            url: '/tracker-dog-marker.png',
            scaledSize: new gm.Size(48, 48),
            anchor: new gm.Point(24, 24),
          },
        });
      } else {
        truckMarker.setPosition(op);
        homeMarker.setPosition(dest);
      }
      if (!mapFitted) {
        const bounds = new gm.LatLngBounds();
        bounds.extend(op); bounds.extend(dest);
        map.fitBounds(bounds, 48);
        mapFitted = true;
      }
    } catch { /* no map is fine; the ETA number still carries the moment */ }
  }

  async function refreshEta() {
    if (!token) return;
    try {
      const r = await fetch(`${SUPABASE_URL}/functions/v1/tracker-eta`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token }),
      });
      if (!r.ok) return;
      const d = await r.json();
      if (!d || !d.live) { etaEl.hidden = true; return; }
      etaEl.hidden = false;
      etaMinEl.textContent = d.eta_minutes != null ? String(d.eta_minutes) : '--';
      const age = Number(d.fix_age_seconds || 0);
      etaFreshEl.textContent = age < 45 ? 'live, updated just now' : `live, as of ${Math.round(age / 60) || 1} min ago`;
      if (d.operator && d.dest) ensureMap(d.operator, d.dest);
    } catch { /* next poll gets it */ }
  }
  function scheduleEta(stage: string) {
    if (etaTimer) { clearTimeout(etaTimer); etaTimer = null; }
    if (stage !== 'on_the_way') { etaEl.hidden = true; return; }
    refreshEta();
    const loop = () => { etaTimer = setTimeout(async () => { await refreshEta(); loop(); }, 20000); };
    loop();
  }

  // ── The status loop ────────────────────────────────────────────────────
  let prevStage: string | null = null;
  let lastPollAt = 0;

  async function refresh() {
    if (!token) { missingEl.hidden = false; titleEl.textContent = 'No visit on this link.'; return; }
    const { data, error } = await client.rpc('tracker_status', { p_token: token });
    if (error || !data || !data.found) {
      if (cardEl.hidden) { missingEl.hidden = false; titleEl.textContent = 'No visit on this link.'; }
      return;
    }
    const stage = String(data.stage || 'scheduled');
    if (stage === 'inactive' || stage === 'expired') {
      missingEl.hidden = false;
      cardEl.hidden = true;
      meetEl.hidden = true;
      if (stage === 'expired') {
        titleEl.textContent = 'This visit has wrapped.';
        missingTextEl.textContent = 'Tracker links retire a week after the visit. Your photos and visit history live on in your portal.';
        missingLinkEl.textContent = 'Open your portal';
        missingLinkEl.href = '/portal';
      } else {
        titleEl.textContent = 'This visit is no longer scheduled.';
      }
      subEl.textContent = '';
      return;
    }
    missingEl.hidden = true;
    cardEl.hidden = false;
    meetEl.hidden = false;

    applyOperator(data.operator);
    titleEl.textContent = headline(stage, data.dogs || []);
    subEl.textContent = data.first_name ? `Hi ${data.first_name}. This page updates on its own; keep it open or check back any time.` : 'This page updates on its own; keep it open or check back any time.';

    const idx = STAGES.indexOf(stage);
    document.querySelectorAll('#trk-steps li').forEach((li) => {
      const i = STAGES.indexOf(li.getAttribute('data-stage') || '');
      li.classList.toggle('is-active', i === idx);
      li.classList.toggle('is-done', i < idx);
    });

    if (data.scheduled_start && data.scheduled_end) {
      const s = new Date(data.scheduled_start);
      const e = new Date(data.scheduled_end);
      blockEl.textContent = `${dayFmt.format(s)}, in the ${timeFmt.format(s)} to ${timeFmt.format(e)} block. The work happens inside the block; the opening minute is not an arrival promise.`;
    } else {
      blockEl.textContent = '';
    }

    // Chime only for a change observed LIVE: the page visible and the last
    // poll recent. A backgrounded tab catches up silently, so nobody gets a
    // doorbell an hour after the truck arrived (and left).
    const live = !document.hidden && lastPollAt > 0 && Date.now() - lastPollAt < 60000;
    if (prevStage !== null && prevStage !== stage && live) announce(stage);
    if (prevStage !== stage) scheduleEta(stage);
    prevStage = stage;
    lastPollAt = Date.now();
  }

  // Photos Paul shared from this visit, via the tracker-photos edge function
  // (a token visitor has no auth for storage RLS, so URLs are signed
  // server-side; only deliberately shared photos for this one visit return).
  // Today the operator is Paul; when routes carry operators this reads from
  // the route (specialist_named_not_promised), same as the who-block above.
  let OPERATOR_FIRST = 'Paul';
  // The appointment carries its operator (Paul or Jake or whoever rolls);
  // the page names and labels follow it, switchable up to the last minute.
  function applyOperator(op: any) {
    if (!op || !op.first) return;
    OPERATOR_FIRST = op.first;
    const whoName = document.getElementById('trk-who-name');
    const meetName = document.getElementById('trk-meet-name');
    if (op.name && whoName) whoName.textContent = op.name;
    if (op.name && meetName) meetName.textContent = op.name;
    if (op.title && op.title.indexOf('Owner') < 0) {
      const whoRole = document.getElementById('trk-who-role');
      if (whoRole) whoRole.textContent = op.title + '. The one rolling up to your driveway.';
    }
  }
  const PHOTO_LABELS: Record<string, string> = { before: 'Before', after: 'After', with_dog: `With ${OPERATOR_FIRST}`, extra: 'Extra' };
  function photoLabel(p: { kind: string; dog_name?: string | null }) {
    if (p.kind === 'with_dog') return p.dog_name ? `${OPERATOR_FIRST} and ${p.dog_name}` : `With ${OPERATOR_FIRST}`;
    const base = PHOTO_LABELS[p.kind] || 'Photo';
    return p.dog_name ? `${base}, ${p.dog_name}` : base;
  }
  const photosEl = document.getElementById('trk-photos')!;
  const photosGrid = document.getElementById('trk-photos-grid')!;
  const collagesEl = document.getElementById('trk-collages')!;

  // Before-and-after, side by side, thin white divider, nothing flowery:
  // the thing a proud client actually shares. Built right here on the page
  // (the signed URLs allow it), one collage per dog when photos are tagged.
  const builtCollages = new Set<string>();
  function loadImg(url: string): Promise<HTMLImageElement> {
    return new Promise((res, rej) => {
      const img = new Image();
      img.crossOrigin = 'anonymous';
      img.onload = () => res(img);
      img.onerror = rej;
      img.src = url;
    });
  }
  function drawCover(ctx: CanvasRenderingContext2D, img: HTMLImageElement, x: number, y: number, w: number, h: number) {
    const s = Math.max(w / img.width, h / img.height);
    const sw = w / s; const sh = h / s;
    const sx = (img.width - sw) / 2; const sy = (img.height - sh) / 2;
    ctx.drawImage(img, sx, sy, sw, sh, x, y, w, h);
  }
  async function buildCollages(photos: Array<{ id: string; kind: string; url: string; dog_name?: string | null }>) {
    const groups = new Map<string, { before?: any; after?: any }>();
    for (const p of photos) {
      if (p.kind !== 'before' && p.kind !== 'after') continue;
      const key = p.dog_name || '';
      if (!groups.has(key)) groups.set(key, {});
      const g = groups.get(key)!;
      if (!(g as any)[p.kind]) (g as any)[p.kind] = p;
    }
    for (const [dog, g] of groups) {
      if (!g.before || !g.after) continue;
      const key = `${g.before.id}|${g.after.id}`;
      if (builtCollages.has(key)) continue;
      builtCollages.add(key);
      try {
        const [bi, ai] = await Promise.all([loadImg(g.before.url), loadImg(g.after.url)]);
        const S = 800; const GAP = 8;
        const canvas = document.createElement('canvas');
        canvas.width = S * 2 + GAP; canvas.height = S;
        const ctx = canvas.getContext('2d')!;
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        drawCover(ctx, bi, 0, 0, S, S);
        drawCover(ctx, ai, S + GAP, 0, S, S);
        const blob: Blob | null = await new Promise((res) => canvas.toBlob(res, 'image/jpeg', 0.9));
        if (!blob) continue;
        const url = URL.createObjectURL(blob);
        const img = document.createElement('img');
        img.src = url;
        img.alt = dog ? `${dog}, before and after` : 'Before and after';
        img.title = 'Tap to share';
        img.addEventListener('click', async () => {
          const file = new File([blob], `${(dog || 'before-after').toLowerCase().replace(/\s+/g, '-')}.jpg`, { type: 'image/jpeg' });
          if (navigator.canShare && navigator.canShare({ files: [file] })) {
            try { await navigator.share({ files: [file] }); return; } catch { /* closed the sheet */ }
          } else {
            window.open(url, '_blank');
          }
        });
        const hint = document.createElement('p');
        hint.className = 'trk-collage__hint';
        hint.textContent = `${dog ? dog + ': ' : ''}before and after. Tap to share.`;
        collagesEl.append(img, hint);
        collagesEl.hidden = false;
      } catch { /* a collage is a bonus; the strip stands on its own */ }
    }
  }

  async function refreshPhotos() {
    if (!token) return;
    try {
      const r = await fetch(`${SUPABASE_URL}/functions/v1/tracker-photos`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token }),
      });
      if (!r.ok) return;
      const data = await r.json();
      // Returning clients see Paul with THEIR dog on the who's-coming card,
      // from their own shared visit history; new clients keep the cover.
      const who = data && data.who_is_coming;
      if (who && who.url) {
        const meetImg = document.getElementById('trk-meet-img') as HTMLImageElement | null;
        if (meetImg && meetImg.src !== who.url) {
          meetImg.src = who.url;
          meetImg.alt = who.dog_name ? `Paul with ${who.dog_name}` : 'Paul with your dog';
        }
      }
      const photos = (data && data.photos) || [];
      if (photos.length === 0) return;
      photosGrid.replaceChildren(...photos.map((p: { id: string; kind: string; url: string; dog_name?: string }) => {
        const a = document.createElement('a');
        a.href = p.url;
        a.target = '_blank';
        a.rel = 'noreferrer';
        const img = document.createElement('img');
        img.src = p.url;
        img.loading = 'lazy';
        img.alt = photoLabel(p);
        const label = document.createElement('span');
        label.textContent = photoLabel(p);
        a.append(img, label);
        return a;
      }));
      photosEl.hidden = false;
      buildCollages(photos);
    } catch { /* photos are a bonus; the tracker never breaks over them */ }
  }

  // Poll faster while the visit is moving (the doorbell moment should not
  // lag), settle down when nothing is happening.
  function statusLoop() {
    const fast = prevStage === 'on_the_way' || prevStage === 'arrived' || prevStage === 'underway' || prevStage === 'returning';
    setTimeout(async () => { await refresh(); statusLoop(); }, fast ? 15000 : 45000);
  }

  // Coming back to the tab resyncs immediately (and silently, via the
  // freshness guard above).
  document.addEventListener('visibilitychange', () => {
    if (!document.hidden) refresh();
  });

  refresh().then(statusLoop);
  refreshPhotos();
  setInterval(refreshPhotos, 60000);
</script>
