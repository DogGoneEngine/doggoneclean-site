---
// src/pages/index.astro
// Home page. Funnel for the Hurricane Bath: introduce, justify, point
// people at /the-villages (the city page where the offer lives) and
// /process (the work explained). The deep detail does not live here.
//
// Service area names Clean's served cities, The Villages and Ocala
// (`ocala_is_a_served_city`); unserved cities stay off the copy.
import BaseLayout from '../layouts/BaseLayout.astro';

const valueProps = [
  {
    title: 'The Hurricane Bath',
    body: 'A wash system Paul built himself. Powerful when it needs to be, gentle when it has to be. Strong flow drives water through a thick coat to the skin. A soft trickle for faces, eyes, and nervous dogs. No fire hosing where it does not belong.',
  },
  {
    title: 'Built around the dog',
    body: 'We bath one household at a time in a climate controlled trailer. No cages, no assembly line, no crowded lobby. Your dog gets focused care and the trailer rolls on.',
  },
  {
    title: 'We come to you',
    body: 'The trailer parks in your driveway. The bath happens. Your dog walks back inside clean. You stay home. Your day stays yours.',
  },
];

const loopSteps = [
  'You notice the shedding piling up on the rug and the couch.',
  'You think about giving the bath yourself. The hose is cold, the dog hates it, the mess is enormous.',
  'You think about loading the dog up and driving somewhere. The wait. The pickup. Half a day gone.',
  'So you put it off. The shedding gets worse. So does the smell.',
  'The cycle repeats. You think about it again next week.',
];

const recurringSteps = [
  'Book your first visit',
  'Try the Hurricane Bath',
  'We come back on a schedule you keep',
  'Cancel in two taps, anytime',
];
---

<BaseLayout
  title="Dog Gone Clean | Mobile dog baths in The Villages and Ocala, Florida"
  description="A genuinely clean dog in your driveway, powered by the Hurricane Bath. Recurring or one off, in The Villages and Ocala, Florida."
>

  <!-- HERO -->
  <section class="hero">
    <div class="glow glow-a"></div>
    <div class="glow glow-b"></div>
    <div class="container">
      <div class="hero__inner">
        <p class="eyebrow">Mobile dog baths, in your driveway</p>
        <h1 class="hero__title">A bath your dog<br /><span class="grad">actually likes.</span></h1>
        <p class="hero__lede">
          Powered by the Hurricane Bath, in your driveway. A genuinely clean
          dog, calmly handled, without the trip.
        </p>
        <div class="hero__cta">
          <a class="button button--primary button--lg" href="/the-villages">Book a visit</a>
          <a class="button button--ghost button--lg" href="/process">Meet the Hurricane Bath</a>
        </div>
        <p class="hero__trio">Structured. Reliable. Personal.</p>
      </div>
    </div>
  </section>

  <!-- FAST LANE -->
  <section class="fast-lane">
    <div class="container">
      <div class="fast-lane__inner">
        <a href="/the-villages" class="fast-lane-card fast-lane-card--new">
          <div class="fast-lane-card__icon" aria-hidden="true">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M12 5v14M5 12h14"/>
            </svg>
          </div>
          <div>
            <div class="fast-lane-card__label">New here</div>
            <div class="fast-lane-card__desc">See the offer in The Villages</div>
          </div>
        </a>
        <a href="/portal" class="fast-lane-card fast-lane-card--existing">
          <div class="fast-lane-card__icon" aria-hidden="true">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M9 14l-4-4 4-4"/>
              <path d="M5 10h11a4 4 0 010 8h-1"/>
            </svg>
          </div>
          <div>
            <div class="fast-lane-card__label">Existing client</div>
            <div class="fast-lane-card__desc">Manage your recurring care</div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- VALUE PROPS -->
  <section class="section">
    <div class="container">
      <div class="text-center">
        <p class="section-label">What makes this different</p>
        <h2 class="section-title">A clean dog is the real job here.</h2>
        <p class="section-subtitle section-subtitle--center">
          Dog Gone Clean does one thing: bath dogs, in their driveway, with
          a system Paul designed to do it well. No salon theater, no
          add ons, no upsells. One clean dog at a time.
        </p>
      </div>
      <div class="value-grid">
        {valueProps.map(v => (
          <article class="value-card">
            <h3>{v.title}</h3>
            <p>{v.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- THE LOOP -->
  <section class="section loop-section">
    <div class="container">
      <div class="text-center">
        <p class="section-label">The problem we solve</p>
        <h2 class="section-title">You know it needs to get done.</h2>
        <p class="section-subtitle section-subtitle--center">
          Bathing the dog is one of those tasks that keeps getting pushed
          to next week. Here is how the cycle usually plays out.
        </p>
      </div>
      <div class="loop-grid">
        <ol class="loop-list">
          {loopSteps.map((step, i) => (
            <li>
              <span class="loop-marker">{i + 1}</span>
              <span>{step}</span>
            </li>
          ))}
        </ol>
        <div class="loop-solution">
          <h3>Break the loop.</h3>
          <p>
            Dog Gone Clean takes the bath off your plate. We show up at
            your home on a schedule you set, run the Hurricane Bath, and
            roll on. You stop thinking about it. You stop putting it off.
            It just gets done.
          </p>
          <a class="button button--primary" href="/the-villages">See the offer</a>
        </div>
      </div>
    </div>
  </section>

  <!-- RECURRING MODEL -->
  <section class="section">
    <div class="container">
      <div class="text-center">
        <p class="section-label">How it works</p>
        <h2 class="section-title">Set it. Forget it. <span class="grad">Stay ahead of the shed.</span></h2>
        <p class="section-subtitle section-subtitle--center">
          Most clients pick recurring every four weeks. Heavy shedders go
          every two. Same price either way. Book once and the rest runs
          on a standing schedule.
        </p>
      </div>
      <div class="recurring">
        <div class="recurring__copy">
          <h3>Recurring, your way</h3>
          <p>
            Your bath runs on the same rhythm every cycle. The Hurricane
            Bath stays ahead of the shedding, the smell, and the dander
            you would rather not vacuum. No reminding yourself. No
            rebooking. No hassle.
          </p>
          <p>
            You can also book a single visit first and move to recurring
            when you are ready.
          </p>
        </div>
        <ol class="recurring__steps">
          {recurringSteps.map((step, i) => (
            <li>
              <span class="recurring__num">{i + 1}</span>
              <span class="recurring__text">{step}</span>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- SERVICE AREA -->
  <section class="section city-section">
    <div class="container">
      <div class="text-center">
        <p class="section-label">Service area</p>
        <h2 class="section-title">We serve The Villages and Ocala.</h2>
        <p class="section-subtitle section-subtitle--center">
          The Hurricane Bath is live in The Villages, Florida, and coming soon
          to Ocala.
        </p>
      </div>
      <div class="city-grid">
        <a href="/the-villages" class="city-card">
          <div class="city-card__state">Florida</div>
          <h3>The Villages</h3>
          <p>Mobile dog baths in The Villages. Recurring or one off, on a schedule you keep.</p>
          <div class="city-card__cta">
            See the offer
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
        </a>
        <a href="/ocala" class="city-card">
          <div class="city-card__state">Florida · Coming soon</div>
          <h3>Ocala</h3>
          <p>The Hurricane Bath is rolling out in Ocala. Join the waitlist to be first in line when we open.</p>
          <div class="city-card__cta">
            Join the waitlist
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- REAL DOGS, REAL TRAILER -->
  <section class="section trailer-strip">
    <div class="container">
      <div class="text-center">
        <p class="section-label">In the trailer</p>
        <h2 class="section-title">Real dogs, real driveways.</h2>
        <p class="section-subtitle section-subtitle--center">
          Every bath happens in the climate controlled trailer, parked at your home.
        </p>
      </div>
      <div class="trailer-grid">
        <img src="/photos/trailer-1.jpg" loading="lazy" alt="A calm black Lab resting against the tub in the Hurricane Bath trailer" />
        <img src="/photos/trailer-2.jpg" loading="lazy" alt="A Bernese Mountain Dog standing in the bright, clean Hurricane Bath trailer" />
        <img src="/photos/trailer-3.jpg" loading="lazy" alt="Paul with a relaxed yellow Lab in the trailer" />
        <img src="/photos/trailer-4.jpg" loading="lazy" alt="Paul holding a happy little terrier mix, small dogs welcome too" />
      </div>
    </div>
  </section>

  <!-- FRIENDLY DOGS -->
  <section class="section friendly-section">
    <div class="container">
      <div class="text-center">
        <p class="section-label">Safety standard</p>
        <h2 class="section-title">Friendly dogs only</h2>
      </div>
      <div class="friendly__card">
        <p>A mobile dog bath runs on the trust between the dog and the operator.</p>
        <p>A dog that shows aggression toward people is not eligible for this service.</p>
        <p><strong>Normal wiggling is fine. Aggression is not.</strong></p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* HERO */
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-4xl) var(--space-3xl);
  }
  .hero .glow-a {
    top: -120px;
    right: -80px;
    width: 420px;
    height: 420px;
  }
  .hero .glow-b {
    top: 320px;
    left: -120px;
    width: 380px;
    height: 380px;
  }
  .hero__inner {
    max-width: 760px;
    margin-inline: auto;
    text-align: center;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--accent);
    margin: 0 0 var(--space-md);
  }
  .hero__title {
    font-size: clamp(2.6rem, 8vw, 4.4rem);
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-lg);
  }
  .hero__lede {
    font-size: var(--text-xl);
    color: var(--soft);
    line-height: 1.5;
    margin: 0 auto var(--space-xl);
    max-width: 38rem;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    justify-content: center;
  }
  .hero__trio {
    margin: var(--space-xl) 0 0;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--soft);
  }

  /* FAST LANE */
  .fast-lane {
    margin-top: calc(-1 * var(--space-lg));
    position: relative;
    z-index: 2;
  }
  .fast-lane__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    max-width: 760px;
    margin: 0 auto;
  }
  .fast-lane-card {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg) var(--space-xl);
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: var(--ink);
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
  }
  .fast-lane-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent);
    color: var(--ink);
  }
  .fast-lane-card__icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-full);
    display: grid;
    place-items: center;
  }
  .fast-lane-card--new .fast-lane-card__icon {
    background: rgba(37, 99, 235, 0.1);
    color: var(--accent);
  }
  .fast-lane-card--existing .fast-lane-card__icon {
    background: rgba(6, 182, 212, 0.12);
    color: var(--accent2);
  }
  .fast-lane-card__label {
    font-size: var(--text-lg);
    font-weight: 800;
    color: var(--ink);
    line-height: 1.2;
  }
  .fast-lane-card__desc {
    font-size: var(--text-sm);
    color: var(--soft);
    margin-top: 2px;
  }
  @media (max-width: 600px) {
    .fast-lane { margin-top: var(--space-md); }
    .fast-lane__inner { grid-template-columns: 1fr; }
  }

  /* VALUE PROPS */
  .value-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    margin-top: var(--space-3xl);
  }
  @media (max-width: 900px) {
    .value-grid { grid-template-columns: 1fr; }
  }
  .value-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }
  .value-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .value-card h3 {
    font-size: var(--text-xl);
    margin: 0 0 var(--space-sm);
    color: var(--accent);
  }
  .value-card p {
    color: var(--soft);
    margin: 0;
  }

  /* THE LOOP */
  .loop-section {
    background: var(--surface-alt);
    border-block: 1px solid var(--line);
  }
  .loop-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
    margin-top: var(--space-2xl);
  }
  @media (max-width: 900px) {
    .loop-grid { grid-template-columns: 1fr; gap: var(--space-xl); }
  }
  .loop-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .loop-list li {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
    color: var(--soft);
  }
  .loop-marker {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: grid;
    place-items: center;
    background: var(--accent);
    color: #fff;
    border-radius: var(--radius-full);
    font-weight: 800;
  }
  .loop-solution {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    box-shadow: var(--shadow-sm);
  }
  .loop-solution h3 {
    color: var(--accent);
    margin: 0 0 var(--space-md);
  }
  .loop-solution p {
    margin-bottom: var(--space-lg);
  }

  /* RECURRING */
  .recurring {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    margin-top: var(--space-2xl);
    align-items: start;
  }
  @media (max-width: 900px) {
    .recurring { grid-template-columns: 1fr; }
  }
  .recurring__copy h3 {
    color: var(--accent);
    margin: 0 0 var(--space-md);
    font-size: var(--text-2xl);
  }
  .recurring__steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .recurring__steps li {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-md) var(--space-lg);
  }
  .recurring__num {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: #fff;
    border-radius: var(--radius-full);
    font-weight: 800;
  }
  .recurring__text {
    color: var(--ink);
    font-weight: 600;
  }

  /* CITY */
  .city-section {
    background: var(--surface-alt);
    border-block: 1px solid var(--line);
    scroll-margin-top: var(--nav-height);
  }
  .city-grid {
    display: grid;
    grid-template-columns: minmax(0, 480px);
    justify-content: center;
    gap: var(--space-lg);
    margin-top: var(--space-2xl);
  }
  .city-card {
    display: block;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
    text-align: left;
  }
  .city-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent);
    color: inherit;
  }
  .city-card__state {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent2);
    margin-bottom: var(--space-xs);
  }
  .city-card h3 {
    font-size: var(--text-2xl);
    color: var(--accent);
    margin: 0 0 var(--space-sm);
  }
  .city-card p {
    color: var(--soft);
    margin: 0 0 var(--space-lg);
  }
  .city-card__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--accent);
    font-weight: 700;
    font-size: var(--text-sm);
  }

  /* FRIENDLY */
  .friendly-section { }
  .friendly__card {
    max-width: 640px;
    margin: var(--space-2xl) auto 0;
    padding: var(--space-2xl);
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    text-align: center;
    box-shadow: var(--shadow-sm);
  }
  .friendly__card p {
    margin-bottom: var(--space-md);
    font-size: var(--text-lg);
  }
  .friendly__card p:last-child { margin-bottom: 0; }

  /* REAL DOGS, REAL TRAILER */
  .trailer-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
    max-width: 900px;
    margin: var(--space-2xl) auto 0;
  }
  .trailer-grid img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-lg);
    display: block;
    box-shadow: var(--shadow-sm);
  }
  @media (min-width: 800px) {
    .trailer-grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>
