---
const services = [
  {
    name: "The Bath",
    body: "A thorough wash, dry, ears, and nails at your door, powered by the Hurricane Bath. Fast, calm, and a genuinely clean dog. Our core service for every dog that does not need a haircut.",
  },
  {
    name: "The Full Groom",
    body: "Breed and coat specific haircuts, hand finished. The full groom continues for the longtime clients we have served for years, the same familiar face every visit.",
  },
];

const bathPoints = [
  {
    head: "Power, dialed to the dog",
    body: "A lever at the nozzle sets the water from a soft trickle to full force. Full force drives water through a thick double coat to the skin. Soft is right for a face, eyes, and nervous dogs. Powerful does not have to mean rough.",
  },
  {
    head: "Finishes on clean water",
    body: "The wash recirculates and gets your dog clean the way a dishwasher does. Every dog finishes with a fresh water rinse from a separate tank.",
  },
  {
    head: "No dog too dirty",
    body: "Mud from nose to tail is a normal day. When the wash water turns to a puddle, we flush, refill, and wash again until your dog washes up clean.",
  },
  {
    head: "Easy on water",
    body: "Most dogs are washed and rinsed with under five gallons. The power comes from how the system moves water, not from wasting it.",
  },
];

const faqs = [
  {
    q: "Is it gentle?",
    a: "Yes. The pressure dials down to a soft trickle, so faces, eyes, and small or nervous dogs get a soft bath.",
  },
  {
    q: "Is my dog washed in clean water?",
    a: "The wash recirculates and gets your dog clean the way a dishwasher does. An extra-dirty dog is flushed and washed again with fresh water, and every dog finishes on a clean-water rinse from a separate tank.",
  },
  {
    q: "What shampoo do you use?",
    a: "A gentle shampoo and conditioner that suits nearly every dog. If your dog needs something specific, medicated, or for a particular condition, bring it and we will use it.",
  },
  {
    q: "How dirty is too dirty?",
    a: "Just about nothing. Mud from nose to tail is a normal day.",
  },
];

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dog Gone Clean | Mobile dog grooming and baths in the Ocala area</title>
    <meta
      name="description"
      content="Dog Gone Clean is a mobile dog grooming and bath service in the Ocala, Florida area, now leading with the Hurricane Bath. We bring a genuinely clean dog to your driveway."
    />
  </head>
  <body>
    <div class="glow glow-a"></div>
    <div class="glow glow-b"></div>

    <header class="site">
      <img class="brand-logo" src="/logo.png" alt="Dog Gone Clean" />
      <a class="portal" href="/portal/">Client sign in</a>
    </header>

    <main>
      <section class="hero">
        <p class="eyebrow">Mobile dog baths in Ocala</p>
        <h1>Built, <span class="grad">not bought.</span></h1>
        <p class="lede">
          The Hurricane Bath gets your dog genuinely clean, fast, right in your
          driveway. Twenty years of steady hands and one familiar face, with the
          full groom still here for our longtime clients.
        </p>
        <div class="cta">
          <a class="button primary" href="/portal/">Book a visit</a>
          <a class="button ghost" href="#bath">Meet the Hurricane Bath</a>
        </div>
        <p class="trio">Structured. Reliable. Personal.</p>
      </section>

      <section class="why">
        <p class="eyebrow">Why Paul built it</p>
        <h2>None of the systems he could buy did everything he wanted in one machine.</h2>
        <p>
          So he built the one that does. Years of working with the professional
          systems showed him what to keep and what was missing, and he put all of
          it into a single machine tuned exactly the way he wants to wash a dog.
          There is nothing else quite like it, and he is still refining it.
        </p>
      </section>

      <section id="services" class="services">
        <h2>What we do</h2>
        <div class="grid">
          {
            services.map((s) => (
              <article class="card">
                <h3>{s.name}</h3>
                <p>{s.body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section id="bath" class="bath">
        <p class="eyebrow light">The Hurricane Bath</p>
        <h2>A serious bath, <span class="grad">at your door.</span></h2>
        <p class="lede">
          The Hurricane Bath moves up to about ten gallons a minute, the kind of
          flow you get from city water, and dials all the way down to a soft
          trickle for a dog's face and eyes. Paul built it himself, and it gets a
          dog genuinely clean, fast.
        </p>
        <div class="grid">
          {
            bathPoints.map((p) => (
              <article class="card dark">
                <h3>{p.head}</h3>
                <p>{p.body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="faq">
        <p class="eyebrow">Questions, answered</p>
        <h2>Honest answers about the Hurricane Bath.</h2>
        <div class="qa-list">
          {
            faqs.map((f) => (
              <article class="qa">
                <h3>{f.q}</h3>
                <p>{f.a}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="power">
        <h2>Power to spare</h2>
        <p>
          Dog Gone Clean runs on two heavy duty generators, together enough to
          power a small house. Most of that goes straight into what your dog
          actually feels: strong air conditioning, a dehumidifier that keeps the
          trailer cool and dry, and high velocity dryers. Drying is a one two
          punch, so your dog is dry quickly and back to doing what it does best.
        </p>
      </section>

      <section class="doorstep">
        <h2>We come to you</h2>
        <p>
          We bring the entire dog grooming system to your driveway. Our mobile
          unit carries its own water, power, and climate control. We park at your
          home, complete the groom, and send arrival notifications along the way.
          No driving across town. No sitting in a lobby. No disruption to your
          day. You stay home. Your dog gets focused care. The route keeps moving.
        </p>
      </section>

      <section class="area">
        <h2>Where we go</h2>
        <p>We serve Ocala, Florida. We come to you.</p>
      </section>

      <section class="about">
        <h2>Meet Paul Nickerson</h2>
        <p>
          Paul did not fall into this business by accident. He chose dogs. He
          wanted to build his life around working with them, so he trained at the
          Florida Institute of Animal Arts and built Dog Gone Clean from the
          ground up in Ocala, Florida.
        </p>
        <p>
          What started as one trailer and one decision became a focused mobile
          dog grooming service built on calm handling and full attention. The
          system came later. The dogs came first.
        </p>
        <p class="sign">Paul Nickerson, Owner, Dog Gone Clean</p>
      </section>
    </main>

    <footer class="site-footer">
      <span>Dog Gone Clean</span>
      <span>Mobile dog grooming, Ocala FL</span>
    </footer>

    <style>
      :root {
        --ink: #0c1322;
        --muted: #5a6b7d;
        --bg: #f7f9ff;
        --card: #ffffff;
        --accent: #2563eb;
        --accent2: #06b6d4;
        --line: #e3e8f4;
      }
      * {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        position: relative;
        overflow-x: hidden;
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        color: var(--ink);
        background: var(--bg);
        line-height: 1.55;
      }
      .glow {
        position: absolute;
        z-index: 0;
        border-radius: 50%;
        filter: blur(90px);
        opacity: 0.5;
        pointer-events: none;
      }
      .glow-a {
        top: -120px;
        right: -80px;
        width: 420px;
        height: 420px;
        background: radial-gradient(circle, #3b82f6, transparent 70%);
      }
      .glow-b {
        top: 600px;
        left: -120px;
        width: 380px;
        height: 380px;
        background: radial-gradient(circle, #22d3ee, transparent 70%);
      }
      .site,
      main,
      .site-footer {
        position: relative;
        z-index: 1;
      }
      .site {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.1rem 1.4rem;
        max-width: 980px;
        margin: 0 auto;
      }
      .brand-logo {
        height: 40px;
        width: auto;
        display: block;
      }
      .portal {
        color: var(--accent);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
      }
      main {
        max-width: 980px;
        margin: 0 auto;
        padding: 0 1.4rem;
      }
      .eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.09em;
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--accent);
        margin: 0 0 0.7rem;
      }
      .eyebrow.light {
        color: var(--accent2);
      }
      .hero {
        padding: 3rem 0 3.5rem;
      }
      h1 {
        font-size: clamp(2.6rem, 9vw, 4.6rem);
        line-height: 1.02;
        letter-spacing: -0.02em;
        margin: 0 0 1.2rem;
        font-weight: 800;
      }
      .grad {
        background: linear-gradient(100deg, var(--accent), var(--accent2));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      .lede {
        font-size: 1.18rem;
        color: #41506a;
        max-width: 36rem;
        margin: 0 0 1.7rem;
      }
      .cta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
      }
      .button {
        display: inline-block;
        padding: 0.85rem 1.4rem;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 700;
      }
      .primary {
        background: linear-gradient(100deg, var(--accent), var(--accent2));
        color: #fff;
        box-shadow: 0 10px 30px rgba(37, 99, 235, 0.35);
      }
      .ghost {
        background: #fff;
        color: var(--ink);
        border: 1px solid var(--line);
      }
      .trio {
        margin: 1.8rem 0 0;
        font-weight: 700;
        letter-spacing: 0.04em;
        color: #41506a;
      }
      section h2 {
        font-size: clamp(1.6rem, 4vw, 2.2rem);
        letter-spacing: -0.01em;
        margin: 0 0 1.2rem;
        font-weight: 800;
      }
      .services,
      .power,
      .doorstep,
      .area,
      .about,
      .why,
      .faq {
        padding: 1.8rem 0 2.6rem;
      }
      .why h2 {
        max-width: 40rem;
        line-height: 1.18;
      }
      .why p {
        font-size: 1.08rem;
        color: #41506a;
        max-width: 44rem;
        margin: 0;
      }
      .faq h2 {
        max-width: 40rem;
      }
      .qa-list {
        display: grid;
        gap: 0.9rem;
        max-width: 46rem;
      }
      .qa {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 1.1rem 1.3rem;
        box-shadow: 0 4px 14px rgba(13, 30, 70, 0.04);
      }
      .qa h3 {
        margin: 0 0 0.35rem;
        font-size: 1.05rem;
        color: var(--accent);
      }
      .qa p {
        margin: 0;
        color: #41506a;
      }
      .grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
      }
      .card {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 1.4rem;
        box-shadow: 0 6px 20px rgba(13, 30, 70, 0.05);
      }
      .card h3 {
        margin: 0 0 0.5rem;
        color: var(--accent);
      }
      .card p {
        margin: 0;
        color: #41506a;
      }
      .bath {
        position: relative;
        margin: 1rem -1.4rem;
        padding: 3rem 1.4rem;
        color: #eaf2ff;
        background: linear-gradient(160deg, #0c1322, #15233f 60%, #0e2a3a);
        border-radius: 24px;
      }
      .bath h2 {
        color: #fff;
      }
      .bath .lede {
        color: #b9cae8;
      }
      .card.dark {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.12);
        box-shadow: none;
      }
      .card.dark h3 {
        color: #67e8f9;
      }
      .card.dark p {
        color: #b9cae8;
      }
      .power p,
      .doorstep p,
      .area p,
      .about p {
        font-size: 1.08rem;
        color: #41506a;
        max-width: 44rem;
        margin: 0 0 1rem;
      }
      .chips {
        list-style: none;
        padding: 0;
        margin: 1rem 0 0;
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
      }
      .chips li {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 0.45rem 1rem;
        font-size: 0.95rem;
        font-weight: 600;
      }
      .about .sign {
        font-weight: 700;
        color: var(--ink);
      }
      .site-footer {
        max-width: 980px;
        margin: 0 auto;
        padding: 2.5rem 1.4rem 3.5rem;
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.5rem;
        color: #5a6b7d;
        font-size: 0.9rem;
        border-top: 1px solid var(--line);
      }
    </style>
  </body>
</html>
