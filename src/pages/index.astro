---
// src/pages/index.astro
// Home page. Funnel for the Hurricane Bath: introduce, justify, point
// people at /the-villages (the city page where the offer lives) and
// /hurricane-bath (the work explained). The deep detail does not live here.
//
// Service area names Clean's served cities, The Villages and Ocala
// (`ocala_is_a_served_city`); unserved cities stay off the copy.
import BaseLayout from '../layouts/BaseLayout.astro';

const valueProps = [
  {
    title: 'The Hurricane Bath',
    body: 'A wash system Paul built himself. Powerful when it needs to be, gentle when it has to be. Strong flow drives water through a thick coat to the skin. A soft trickle for faces, eyes, and nervous dogs. No fire hosing where it does not belong.',
  },
  {
    title: 'The whole job, one price',
    body: 'The Hurricane Bath is the centerpiece, not the whole show. Deshedding, nail care, foot pad hair, a full high velocity dry in the climate controlled trailer. Everything your dog needs except a haircut they do not need. No add ons, because nothing is held back to upsell.',
  },
  {
    title: 'Built around the dog',
    body: 'One household at a time in a climate controlled trailer. No cages, no assembly line, no crowded lobby. Dogs live as a pack, so when your dogs are calm together, they stay together; if one needs space while the other is worked on, we adjust. Less stress, steadier dogs.',
  },
  {
    title: 'We come to you',
    body: 'The trailer parks in your driveway. The work happens. Your dog walks back inside clean, dry, and done. You stay home. Your day stays yours.',
  },
];

const dogKinds = [
  {
    name: 'The easy kind',
    examples: 'Pit bulls, Boxers, Labs',
    body: 'Smooth, short single coats. They wash fast, dry fast, and walk out gleaming. The quickest visit and the lowest price.',
  },
  {
    name: 'The full-coat kind',
    examples: 'Golden Retrievers, German Shepherds, Australian Shepherds',
    body: 'Thick double coats that shed for a living. More time, more work, a deeper deshed, and priced for it. The transformation is worth photographing.',
  },
];

const loopSteps = [
  'You notice the shedding piling up on the rug and the couch.',
  'You think about giving the bath yourself. The hose is cold, the dog hates it, the mess is enormous.',
  'You think about loading the dog up and driving somewhere. The wait. The pickup. Half a day gone.',
  'So you put it off. The shedding gets worse. So does the smell.',
  'The cycle repeats. You think about it again next week.',
];

const recurringSteps = [
  'Book your first visit',
  'Try the Hurricane Bath',
  'We come back on a schedule you keep',
  'Cancel in two taps, anytime',
];
---

<BaseLayout
  title="Dog Gone Clean | Mobile dog grooming for dogs that don't need haircuts | Ocala and The Villages, Florida"
  description="Full dog grooming in your driveway for dogs that don't need haircuts: the Hurricane Bath, deshedding, nails, the works. Ocala and The Villages, Florida."
>

  <!-- HERO -->
  <section class="hero">
    <div class="glow glow-a"></div>
    <div class="glow glow-b"></div>
    <div class="container">
      <div class="hero__inner">
        <p class="eyebrow">Mobile dog grooming, in your driveway</p>
        <h1 class="hero__title">The full groom.<br /><span class="grad">Minus the haircut they don't need.</span></h1>
        <p class="hero__lede">
          The Hurricane Bath, a deep deshed, nails done, dried to the skin,
          all in your driveway. Everything your dog needs, calmly handled,
          without the trip.
        </p>
        <div class="hero__cta">
          <a class="button button--primary button--lg" href="/book">Book a visit</a>
          <a class="button button--ghost button--lg" href="/hurricane-bath">Meet the Hurricane Bath</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAST LANE -->
  <section class="fast-lane">
    <div class="container">
      <div class="fast-lane__inner">
        <a href="/#cities" class="fast-lane-card fast-lane-card--new">
          <div class="fast-lane-card__icon" aria-hidden="true">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M12 5v14M5 12h14"/>
            </svg>
          </div>
          <div>
            <div class="fast-lane-card__label">New here</div>
            <div class="fast-lane-card__desc">See the offer where you live</div>
          </div>
        </a>
        <a href="/portal" class="fast-lane-card fast-lane-card--existing">
          <div class="fast-lane-card__icon" aria-hidden="true">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M9 14l-4-4 4-4"/>
              <path d="M5 10h11a4 4 0 010 8h-1"/>
            </svg>
          </div>
          <div>
            <div class="fast-lane-card__label">Existing client</div>
            <div class="fast-lane-card__desc">Manage your recurring care</div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- VALUE PROPS -->
  <section class="section">
    <div class="container">
      <div class="text-center">
        <p class="section-label">What makes this different</p>
        <h2 class="section-title">Not a spa. Not a salon.</h2>
        <p class="section-subtitle section-subtitle--center">
          A structured mobile dog grooming system built for calm dogs and
          consistent results. Full dog grooming for dogs that do not need
          haircuts, in your own driveway, with a system Paul designed to do
          it superbly. Every decision exists to produce clean dogs and
          predictable results.
        </p>
      </div>
      <div class="value-grid">
        {valueProps.map(v => (
          <article class="value-card">
            <h3>{v.title}</h3>
            <p>{v.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- TWO KINDS OF DOGS -->
  <section class="section kinds-section">
    <div class="container">
      <div class="text-center">
        <p class="section-label">Is your dog our kind of dog?</p>
        <h2 class="section-title">Two kinds of dogs. <span class="grad">You'll know yours instantly.</span></h2>
        <p class="section-subtitle section-subtitle--center">
          If your dog never gets a haircut, you are in the right place.
          There are two kinds, and a mixed breed just picks by its coat.
        </p>
      </div>
      <div class="kinds-grid">
        {dogKinds.map(k => (
          <article class="kind-card">
            <h3>{k.name}</h3>
            <p class="kind-card__examples">{k.examples}</p>
            <p>{k.body}</p>
          </article>
        ))}
      </div>
      <div class="kinds-honest">
        <p>
          <strong>And we are honest about who we are not built for.</strong>
          Dogs that need haircuts, doodles and poodle crosses, Siberian
          Huskies, Great Pyrenees, and Great Danes need more time than a
          mobile route can give one stop. We would rather tell you here,
          kindly, than at your door. A full-service dog grooming salon is
          the right home for those coats.
        </p>
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="section gallery-section">
    <div class="container">
      <div class="text-center">
        <p class="section-label">In the trailer</p>
        <h2 class="section-title">Real dogs, real driveways.</h2>
        <p class="section-subtitle section-subtitle--center">
          Every bath happens in the climate controlled trailer, parked at your
          home. Calm dogs, clean dogs, no trip to a salon.
        </p>
      </div>
      <!-- Curated fallback shots. Once enough real dogs are approved to the
           gallery, the script below replaces these with the live wall. -->
      <div class="gallery" id="home-gallery-grid">
        <img src="/photos/gallery-1.jpg" loading="lazy" alt="Paul with a calm black Lab in the Hurricane Bath trailer" />
        <img src="/photos/gallery-2.jpg" loading="lazy" alt="Paul with a relaxed yellow Lab in the trailer" />
        <img src="/photos/gallery-3.jpg" loading="lazy" alt="Paul with a happy white German Shepherd in the bright trailer" />
      </div>
    </div>
  </section>

  <script>
    // The living wall of clean dogs: pull the owner-approved gallery photos and,
    // only when there are enough to look full, replace the curated fallback with
    // them. Below the floor the homepage keeps the three baseline shots, so it
    // never looks thin (photo_destinations).
    import { createClient } from '@supabase/supabase-js';
    import { SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY } from '../components/portal/supabase.js';
    const MIN_TO_SHOW = 6;
    const grid = document.getElementById('home-gallery-grid');
    if (grid) {
      const client = createClient(SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY, {
        auth: { persistSession: false, autoRefreshToken: false, detectSessionInUrl: false },
      });
      client.rpc('website_gallery').then(({ data }) => {
        const photos = Array.isArray(data) ? data : [];
        if (photos.length < MIN_TO_SHOW) return;
        grid.classList.add('gallery--live');
        grid.replaceChildren(...photos.map((p, idx) => {
          const fig = document.createElement('figure');
          fig.className = 'gallery__item';
          fig.style.animationDelay = (idx * 0.05) + 's';
          const img = document.createElement('img');
          img.src = p.url;
          img.loading = 'lazy';
          img.alt = p.dog_name ? `${p.dog_name}, freshly bathed by Dog Gone Clean` : 'A freshly bathed dog from Dog Gone Clean';
          fig.append(img);
          if (p.dog_name) {
            const cap = document.createElement('figcaption');
            cap.textContent = p.dog_name;
            fig.append(cap);
          }
          return fig;
        }));
      }).catch(() => { /* the gallery is a bonus; the curated shots stand on their own */ });
    }
  </script>

  <!-- THE LOOP -->
  <section class="section loop-section">
    <div class="container">
      <div class="text-center">
        <p class="section-label">The problem we solve</p>
        <h2 class="section-title">You know it needs to get done.</h2>
        <p class="section-subtitle section-subtitle--center">
          Bathing the dog is one of those tasks that keeps getting pushed
          to next week. Here is how the cycle usually plays out.
        </p>
      </div>
      <div class="loop-grid">
        <ol class="loop-list">
          {loopSteps.map((step, i) => (
            <li>
              <span class="loop-marker">{i + 1}</span>
              <span>{step}</span>
            </li>
          ))}
        </ol>
        <div class="loop-solution">
          <h3>Break the loop.</h3>
          <p>
            Dog Gone Clean takes the bath off your plate. We show up at
            your home on a schedule you set, run the Hurricane Bath, and
            roll on. You stop thinking about it. You stop putting it off.
            It just gets done.
          </p>
          <a class="button button--primary" href="/#cities">See the offer where you live</a>
        </div>
      </div>
    </div>
  </section>

  <!-- RECURRING MODEL -->
  <section class="section">
    <div class="container">
      <div class="text-center">
        <p class="section-label">How it works</p>
        <h2 class="section-title">Set it. Forget it. <span class="grad">Stay ahead of the shed.</span></h2>
        <p class="section-subtitle section-subtitle--center">
          Most clients pick recurring every four weeks. Heavy shedders go
          every two. Same price either way. Book once and the rest runs
          on a standing schedule.
        </p>
      </div>
      <div class="recurring">
        <div class="recurring__copy">
          <h3>Recurring, your way</h3>
          <p>
            We can't change your dog's natural shedding cycle. But on a
            steady routine, we intercept a massive amount of that dead
            undercoat in our trailer before it ever has a chance to land
            on your rugs, your furniture, or your clothes.
          </p>
          <p>
            Your dog's care runs on the same rhythm every cycle. No
            reminding yourself. No rebooking. No hassle.
          </p>
          <p>
            You can also book a single visit first and move to recurring
            when you are ready.
          </p>
        </div>
        <ol class="recurring__steps">
          {recurringSteps.map((step, i) => (
            <li>
              <span class="recurring__num">{i + 1}</span>
              <span class="recurring__text">{step}</span>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- THE STOP BUTTON -->
  <section class="section stop-section">
    <div class="container">
      <div class="text-center">
        <p class="section-label">The stop button</p>
        <h2 class="section-title">Cancel in two taps. <span class="grad">No phone calls, no scripts, no guilt.</span></h2>
      </div>
      <div class="stop-card">
        <p class="stop-card__big">
          Two taps in your portal and it is done. We stop charging.
          We stop coming.
        </p>
        <p>
          No number to call. No hold music. No call center reading a
          retention script while your card keeps getting charged. The stop
          button is yours, it is two taps away, and it works.
        </p>
        <p>
          That is why starting is easy: you are never more than two taps
          from out. We keep you by being worth keeping.
        </p>
      </div>
    </div>
  </section>

  <!-- SERVICE AREA -->
  <section class="section city-section" id="cities">
    <div class="container">
      <div class="text-center">
        <p class="section-label">Service area</p>
        <h2 class="section-title">We serve Ocala and The Villages.</h2>
        <p class="section-subtitle section-subtitle--center">
          Dog Gone Clean has groomed Ocala's dogs for over 20 years. The Villages
          is next, and the founders rate is how you get in early.
        </p>
      </div>
      <div class="city-grid">
        <a href="/ocala" class="city-card">
          <div class="city-card__state">Florida · Over 20 years strong</div>
          <h3>Ocala</h3>
          <p>Home base. New client signups are opening soon, for dogs that do not need haircuts. Join the waitlist to be first in line.</p>
          <div class="city-card__cta">
            Join the waitlist
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
        </a>
        <a href="/the-villages" class="city-card">
          <div class="city-card__state">Florida · Coming soon</div>
          <h3>The Villages</h3>
          <p>The route is being built now. Founders pricing for the first households in, locked for a year.</p>
          <div class="city-card__cta">
            See the founders offer
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- FRIENDLY DOGS -->
  <section class="section friendly-section">
    <div class="container">
      <div class="text-center">
        <p class="section-label">Safety standard</p>
        <h2 class="section-title">Friendly dogs only</h2>
      </div>
      <div class="friendly__card">
        <p>A mobile dog grooming visit runs on the trust between the dog and the Hurricane Bath Operator.</p>
        <p>A dog that shows aggression toward people is not eligible for this service.</p>
        <p><strong>Normal wiggling is fine. Aggression is not.</strong></p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* HERO */
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-4xl) var(--space-3xl);
  }
  .hero .glow-a {
    top: -120px;
    right: -80px;
    width: 420px;
    height: 420px;
  }
  .hero .glow-b {
    top: 320px;
    left: -120px;
    width: 380px;
    height: 380px;
  }
  .hero__inner {
    max-width: 760px;
    margin-inline: auto;
    text-align: center;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--accent);
    margin: 0 0 var(--space-md);
  }
  .hero__title {
    font-size: clamp(2.6rem, 8vw, 4.4rem);
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-lg);
  }
  .hero__lede {
    font-size: var(--text-xl);
    color: var(--soft);
    line-height: 1.5;
    margin: 0 auto var(--space-xl);
    max-width: 38rem;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    justify-content: center;
  }
  .hero__trio {
    margin: var(--space-xl) 0 0;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--soft);
  }

  /* FAST LANE */
  .fast-lane {
    margin-top: calc(-1 * var(--space-lg));
    position: relative;
    z-index: 2;
  }
  .fast-lane__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    max-width: 760px;
    margin: 0 auto;
  }
  .fast-lane-card {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg) var(--space-xl);
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: var(--ink);
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
  }
  .fast-lane-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent);
    color: var(--ink);
  }
  .fast-lane-card__icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-full);
    display: grid;
    place-items: center;
  }
  .fast-lane-card--new .fast-lane-card__icon {
    background: rgba(37, 99, 235, 0.1);
    color: var(--accent);
  }
  .fast-lane-card--existing .fast-lane-card__icon {
    background: rgba(6, 182, 212, 0.12);
    color: var(--accent2);
  }
  .fast-lane-card__label {
    font-size: var(--text-lg);
    font-weight: 800;
    color: var(--ink);
    line-height: 1.2;
  }
  .fast-lane-card__desc {
    font-size: var(--text-sm);
    color: var(--soft);
    margin-top: 2px;
  }
  @media (max-width: 600px) {
    .fast-lane { margin-top: var(--space-md); }
    .fast-lane__inner { grid-template-columns: 1fr; }
  }

  /* VALUE PROPS */
  .value-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
    margin-top: var(--space-3xl);
  }
  @media (max-width: 900px) {
    .value-grid { grid-template-columns: 1fr; }
  }

  /* TWO KINDS */
  .kinds-section {
    background: var(--surface-alt);
    border-block: 1px solid var(--line);
  }
  .kinds-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    max-width: 880px;
    margin: var(--space-2xl) auto 0;
  }
  @media (max-width: 760px) {
    .kinds-grid { grid-template-columns: 1fr; }
  }
  .kind-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-top: 3px solid var(--accent);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    box-shadow: var(--shadow-sm);
  }
  .kind-card h3 {
    color: var(--accent);
    margin: 0 0 var(--space-xs);
    font-size: var(--text-xl);
  }
  .kind-card__examples {
    font-weight: 700;
    color: var(--ink);
    margin: 0 0 var(--space-sm);
  }
  .kind-card p:last-child {
    color: var(--soft);
    margin: 0;
  }
  .kinds-honest {
    max-width: 720px;
    margin: var(--space-xl) auto 0;
    padding: var(--space-lg) var(--space-xl);
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
  }
  .kinds-honest p {
    margin: 0;
    color: var(--soft);
  }

  /* STOP BUTTON */
  .stop-section {
    background: var(--surface-alt);
    border-block: 1px solid var(--line);
  }
  .stop-card {
    max-width: 640px;
    margin: var(--space-2xl) auto 0;
    padding: var(--space-2xl);
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    text-align: center;
    box-shadow: var(--shadow-sm);
  }
  .stop-card__big {
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--ink);
    margin: 0 0 var(--space-md);
  }
  .stop-card p {
    margin-bottom: var(--space-md);
    color: var(--soft);
  }
  .stop-card p:last-child { margin-bottom: 0; }
  .value-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }
  .value-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .value-card h3 {
    font-size: var(--text-xl);
    margin: 0 0 var(--space-sm);
    color: var(--accent);
  }
  .value-card p {
    color: var(--soft);
    margin: 0;
  }

  /* THE LOOP */
  .loop-section {
    background: var(--surface-alt);
    border-block: 1px solid var(--line);
  }
  .loop-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
    margin-top: var(--space-2xl);
  }
  @media (max-width: 900px) {
    .loop-grid { grid-template-columns: 1fr; gap: var(--space-xl); }
  }
  .loop-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .loop-list li {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
    color: var(--soft);
  }
  .loop-marker {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: grid;
    place-items: center;
    background: var(--accent);
    color: #fff;
    border-radius: var(--radius-full);
    font-weight: 800;
  }
  .loop-solution {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    box-shadow: var(--shadow-sm);
  }
  .loop-solution h3 {
    color: var(--accent);
    margin: 0 0 var(--space-md);
  }
  .loop-solution p {
    margin-bottom: var(--space-lg);
  }

  /* RECURRING */
  .recurring {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    margin-top: var(--space-2xl);
    align-items: start;
  }
  @media (max-width: 900px) {
    .recurring { grid-template-columns: 1fr; }
  }
  .recurring__copy h3 {
    color: var(--accent);
    margin: 0 0 var(--space-md);
    font-size: var(--text-2xl);
  }
  .recurring__steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .recurring__steps li {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
