---
// src/pages/ocala.astro
// City page for Ocala: NOT a coming-soon city. Ocala is home base, where
// Dog Gone Clean has groomed dogs for 20 years (ocala_is_a_served_city).
// What IS opening soon here is online booking for NEW clients, which is
// v2.0-only (no-haircut dogs, new_ocala_clients_are_v2_only) and waits on
// the anchor drive-time gate (hb_active false until wired). The waitlist
// captures new-client interest; existing clients go to the portal. The
// no_unpaved_roads rule is stated here because Marion County has unpaved
// roads (The Villages does not, so its surfaces omit it as noise).
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Ocala, Florida | Dog Gone Clean, 20 years of dog grooming"
  description="Dog Gone Clean has groomed Ocala's dogs for 20 years. New client signups are opening soon, for dogs that don't need haircuts: the Hurricane Bath, deshedding, nails, the works, in your own driveway."
>
  <section class="cs-hero">
    <div class="container">
      <span class="cs-hero__tag">Ocala, Florida</span>
      <div class="cs-hero__badge">Home base &middot; 20 years</div>
      <h1>Ocala's dogs have known us<br /><span class="grad">for 20 years.</span></h1>
      <p class="cs-hero__lede">
        Dog Gone Clean started here and never left: full dog grooming, one
        household at a time, in your own driveway. The book is full of
        longtime clients, and something new is opening up.
      </p>
      <p class="cs-hero__sub">
        New client signups are opening soon, for dogs that do not need
        haircuts: the Hurricane Bath, deshedding, nails, the works. Join the
        waitlist to be first in line. Already a client?
        <a href="/portal">Your portal is ready.</a>
      </p>
      <img class="cs-hero__photo" src="/photos/ocala-hero.jpg" loading="lazy" alt="Paul with a calm German Shepherd in the Hurricane Bath trailer" />
    </div>
  </section>

  <section class="section cs-waitlist-section" id="waitlist">
    <div class="container">
      <div class="cs-card">
        <h2>Join the Ocala waitlist</h2>
        <p>We will email you the moment new-client booking opens in Ocala.</p>
        <p class="cs-note">
          One note for new clients: we do not drive on unpaved roads (Marion
          County has plenty). An unpaved driveway is fine.
        </p>

        <form id="waitlist-form" class="cs-form" novalidate data-city-slug="ocala">
          <div class="cs-field">
            <label class="cs-label" for="wl-email">Your email address</label>
            <input class="cs-input" id="wl-email" name="email" type="email" autocomplete="email" required inputmode="email" placeholder="you@example.com" />
          </div>

          <div class="cs-field">
            <label class="cs-label" for="wl-zip">ZIP code (optional)</label>
            <input class="cs-input" id="wl-zip" name="zip_code" type="text" autocomplete="postal-code" inputmode="numeric" maxlength="10" />
          </div>

          <div class="cs-field">
            <label class="cs-label" for="wl-dogs">How many dogs? (optional)</label>
            <select class="cs-input" id="wl-dogs" name="dog_count">
              <option value="">Select</option>
              <option value="1">1 dog</option>
              <option value="2">2 dogs</option>
              <option value="3">3 dogs</option>
              <option value="4">4 or more</option>
            </select>
          </div>

          <button type="submit" class="button button--primary button--lg button--block">Notify me when you launch</button>
          <p class="cs-form__note" id="cs-form-msg" hidden></p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .cs-hero {
    padding: var(--space-5xl) 0 var(--space-2xl);
    background:
      radial-gradient(60% 80% at 20% 0%, rgba(56, 132, 255, 0.16), transparent 70%),
      radial-gradient(50% 70% at 90% 20%, rgba(120, 80, 255, 0.12), transparent 70%);
    text-align: center;
  }
  .cs-hero__tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent, #2563eb);
    margin-bottom: var(--space-sm);
  }
  .cs-hero__badge {
    display: inline-block;
    background: linear-gradient(90deg, #2563eb, #06b6d4);
    color: #fff;
    padding: 4px 14px;
    border-radius: 9999px;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0 0 var(--space-lg) var(--space-sm);
  }
  .cs-hero h1 {
    font-size: clamp(2.2rem, 7vw, 3.8rem);
    line-height: 1.07;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-lg);
  }
  .cs-hero__lede {
    max-width: 38rem;
    margin: 0 auto var(--space-md);
    font-size: var(--text-lg);
    color: var(--color-text-secondary, #475569);
    line-height: 1.7;
  }
  .cs-hero__sub {
    max-width: 34rem;
    margin: 0 auto;
    font-size: var(--text-base);
    color: #64748b;
    line-height: 1.6;
  }
  .cs-hero__photo {
    display: block;
    width: 100%;
    max-width: 340px;
    margin: var(--space-2xl) auto 0;
    border-radius: var(--radius-lg, 18px);
    aspect-ratio: 3 / 4;
    object-fit: cover;
    box-shadow: 0 8px 32px rgba(13, 30, 70, 0.12);
  }

  .cs-waitlist-section { padding-top: var(--space-2xl); }
  .cs-card {
    max-width: 480px;
    margin: 0 auto;
    background: var(--card, #fff);
    border: 1px solid var(--line, #e3e8f4);
    border-radius: var(--radius-lg, 18px);
    padding: var(--space-2xl);
    text-align: center;
  }
  .cs-card h2 { font-size: var(--text-2xl); margin-bottom: var(--space-sm); }
  .cs-card > p { color: #475569; margin-bottom: var(--space-xl); }
  .cs-card .cs-note {
    font-size: var(--text-sm);
    color: #64748b;
    background: #f4f7fd;
    border: 1px solid #e3e8f4;
    border-radius: var(--radius-md, 12px);
    padding: var(--space-md);
    margin-bottom: var(--space-xl);
  }
  .cs-form { display: flex; flex-direction: column; gap: var(--space-md); text-align: left; }
  .cs-field { display: flex; flex-direction: column; gap: 6px; }
  .cs-label { font-size: var(--text-sm); font-weight: 600; color: #334155; }
  .cs-input {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid var(--line, #cbd5e8);
    border-radius: var(--radius-md, 12px);
    font-size: var(--text-base);
    font-family: inherit;
    background: #fff;
  }
  .cs-input:focus { outline: 2px solid var(--accent, #2563eb); outline-offset: 1px; }
  .button--block { width: 100%; margin-top: var(--space-sm); }
  .cs-form__note { margin-top: var(--space-sm); text-align: center; font-size: var(--text-sm); padding: var(--space-md); border-radius: var(--radius-md, 12px); }
  .cs-form__note--success { background: rgba(37, 99, 235, 0.08); color: #1d4ed8; }
  .cs-form__note--error { background: rgba(180, 40, 40, 0.08); color: #b42828; }
</style>

<script>
  const SUPABASE_URL = 'https://urebdrosrxejhubpbxsa.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_3y18WUvZCuW-fiuPywR6nw_BLQyx1h6';

  const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const msg = document.getElementById('cs-form-msg')!;
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      msg.hidden = false;
      msg.className = 'cs-form__note';
      msg.textContent = 'Adding you to the list...';
      submitBtn.disabled = true;

      const fd = new FormData(form);
      const dogVal = fd.get('dog_count') as string;
      const payload = {
        email: ((fd.get('email') as string) || '').trim().toLowerCase(),
        city_slug: form.dataset.citySlug,
        zip_code: ((fd.get('zip_code') as string) || '').trim() || null,
        dog_count: dogVal ? parseInt(dogVal, 10) : null,
      };

      try {
        const res = await fetch(`${SUPABASE_URL}/rest/v1/waitlist`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            apikey: SUPABASE_KEY,
            Authorization: `Bearer ${SUPABASE_KEY}`,
            Prefer: 'return=minimal',
          },
          body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error(await res.text());
        msg.classList.add('cs-form__note--success');
        msg.textContent = "You're on the list. We'll be in touch the moment new-client booking opens.";
        form.reset();
      } catch {
        msg.classList.add('cs-form__note--error');
        msg.textContent = 'Something went wrong. Please try again in a moment.';
        submitBtn.disabled = false;
      }
    });
  }
</script>
