---
// src/pages/ocala.astro
// Hurricane Bath city page for Ocala, the origin of the bath pivot and the
// home of the entire legacy book. Presents Ocala as a served Clean location
// (ocala_is_a_served_city) per Paul's 2026-06-08 direction to reflect Ocala
// on the site.
//
// Posture honors the Oracle gate: Ocala is NOT yet open for new-client v2
// booking (cities.hb_active = false until the anchor drive-time gate is wired
// and flipped on). So this page presents the offer and the location but routes
// new clients to a "booking opens soon" state rather than a live /book CTA that
// would dead-end. Existing clients go to the portal.
//
// new_ocala_clients_are_v2_only: new Ocala clients may only be v2 bath clients.
// Legacy full-groom and nails clients are grandfathered (kept and served), but
// that book is closed to new entries, so this page markets bath only.
//
// Pricing hydrates at build time from the 'ocala' cities row (single source of
// truth, equal to The Villages per ocala_prices_match_villages).
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCityBySlug, cityTiers } from '../lib/cities.js';

const city = await getCityBySlug('ocala');
const tiers = cityTiers(city);
---

<BaseLayout
  title="Dog Gone Clean | Mobile dog baths in Ocala, Florida"
  description="The Hurricane Bath, a genuinely clean dog in your driveway, coming to Ocala, Florida. Bath only, recurring or one off."
>
  <section class="ocala-hero">
    <div class="container">
      <span class="eyebrow">Where Dog Gone Clean began</span>
      <h1>The Hurricane Bath,<br /><span class="grad">now in Ocala.</span></h1>
      <p class="ocala-hero__sub">
        A genuinely clean dog in your own driveway. The same mobile bath that
        serves The Villages, in the town where Dog Gone Clean has groomed dogs
        for two decades.
      </p>
      <div class="ocala-hero__cta">
        <a class="button button--primary button--lg" href="/portal">Existing client sign in</a>
        <a class="button button--ghost button--lg" href="/process">How the bath works</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="text-center">
        <p class="section-label">The bath</p>
        <h2 class="section-title">One inclusive price, by coat.</h2>
        <p class="section-subtitle section-subtitle--center">
          No add-ons, no surprise fees. Each additional dog is $25 less than the
          one before it.
        </p>
      </div>
      <div class="ocala-tiers">
        {tiers.map((t) => (
          <div class="ocala-tier">
            <div class="ocala-tier__label">{t.label}</div>
            <div class="ocala-tier__sub">{t.sub}</div>
            <div class="ocala-tier__price">
              <span class="ocala-tier__dollar">$</span>{t.recurring}
              <span class="ocala-tier__per">per visit, recurring</span>
            </div>
            <div class="ocala-tier__single">or ${t.single} for a single visit</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section ocala-eligibility">
    <div class="container">
      <div class="text-center">
        <p class="section-label">Eligibility</p>
        <h2 class="section-title">Bath dogs, friendly dogs.</h2>
      </div>
      <div class="ocala-elig__card">
        <p>The Hurricane Bath is for dogs that get a bath, not a haircut: coats
          that clean up fast and dry well.</p>
        <p>A dog that shows aggression toward people is not eligible for this
          service. Normal wiggling is fine.</p>
      </div>
    </div>
  </section>

  <section class="section ocala-legacy">
    <div class="container">
      <div class="ocala-legacy__card">
        <p class="section-label">For our Ocala clients</p>
        <h2 class="section-title">Legacy full-groom clients are grandfathered.</h2>
        <p>
          If we already groom your dog in Ocala, nothing changes. You keep your
          full-groom service and your spot on the route. Sign in to your portal
          to see your visits, manage reminders, and update your details.
        </p>
        <a class="button button--primary" href="/portal">Open your portal</a>
        <p class="ocala-legacy__new">
          New to Dog Gone Clean in Ocala? New clients join as Hurricane Bath
          clients. Ocala bath booking opens soon.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .ocala-hero {
    padding: var(--space-5xl) 0 var(--space-4xl);
    background:
      radial-gradient(60% 80% at 20% 0%, rgba(56, 132, 255, 0.16), transparent 70%),
      radial-gradient(50% 70% at 90% 20%, rgba(120, 80, 255, 0.12), transparent 70%);
    text-align: center;
  }
  .ocala-hero h1 {
    font-size: clamp(2.4rem, 8vw, 4.2rem);
    line-height: 1.05;
    margin: var(--space-sm) 0 var(--space-lg);
    letter-spacing: -0.02em;
  }
  .ocala-hero__sub {
    max-width: 38rem;
    margin: 0 auto var(--space-2xl);
    font-size: var(--text-lg);
    color: var(--color-text-secondary, #475569);
    line-height: 1.7;
  }
  .ocala-hero__cta {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .ocala-tiers {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-lg);
    max-width: 720px;
    margin: var(--space-2xl) auto 0;
  }
  .ocala-tier {
    border: 1px solid var(--line, #e3e8f4);
    border-radius: var(--radius-lg, 18px);
    padding: var(--space-xl);
    background: var(--card, #fff);
    text-align: center;
  }
  .ocala-tier__label { font-size: var(--text-xl); font-weight: 800; }
  .ocala-tier__sub { font-size: var(--text-sm); color: #64748b; margin: 6px 0 var(--space-lg); line-height: 1.5; }
  .ocala-tier__price { font-size: 3rem; font-weight: 800; line-height: 1; }
  .ocala-tier__dollar { font-size: 1.5rem; vertical-align: super; font-weight: 700; }
  .ocala-tier__per { display: block; font-size: var(--text-xs); font-weight: 600; color: #64748b; margin-top: 8px; }
  .ocala-tier__single { font-size: var(--text-sm); color: #475569; margin-top: var(--space-md); }

  .ocala-elig__card,
  .ocala-legacy__card {
    max-width: 640px;
    margin: var(--space-xl) auto 0;
    border: 1px solid var(--line, #e3e8f4);
    border-radius: var(--radius-lg, 18px);
    padding: var(--space-2xl);
    background: var(--card, #fff);
  }
  .ocala-elig__card p { margin: 0 0 var(--space-md); line-height: 1.7; }
  .ocala-legacy__card { text-align: center; }
  .ocala-legacy__card p { line-height: 1.7; }
  .ocala-legacy__card h2 { margin-bottom: var(--space-md); }
  .ocala-legacy__card .button { margin-top: var(--space-lg); }
  .ocala-legacy__new {
    margin-top: var(--space-xl);
    font-size: var(--text-sm);
    color: #64748b;
  }
</style>
