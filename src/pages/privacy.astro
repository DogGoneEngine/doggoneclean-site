---
// src/pages/privacy.astro
// Mirrors the Dog Gone Nails privacy policy structure, adapted to Clean's
// context: dog grooming (not nails), Stripe plus Square (in-person legacy
// payments), and Clean's own domain and contact. Business mailing address is
// a single drop-in pending the iPostal1 box.
import Legal from '../layouts/Legal.astro';
---

<Legal title="Privacy Policy" updatedAt="June 2026" description="How Dog Gone Clean handles your information.">
  <h2>Identity of the Business</h2>
  <p>
    Dog Gone Clean<br />
    [mailing address added after iPostal1 setup]<br />
    service@doggoneclean.us
  </p>

  <h2>Information We Collect</h2>
  <p>
    We collect contact and service-related information you provide when booking,
    payment information processed by our payment processors, and standard technical
    information your browser sends when visiting our website.
  </p>

  <h2>Purpose of Collection</h2>
  <p>
    We use this information strictly to schedule and provide dog grooming service,
    process payments, send service-related communications, and comply with legal
    obligations.
  </p>

  <h2>Third Parties</h2>
  <p>
    We utilize the following third-party services to operate: Stripe and Square
    (payments), Twilio (SMS), Resend (email), Google (business email), Supabase
    (data storage), and DigitalOcean (hosting).
  </p>
  <p>
    <strong
      >Mobile phone numbers, SMS consent, and text message content are never
      shared with third parties or affiliates for marketing purposes.</strong
    >
  </p>

  <h2>Security</h2>
  <p>
    We take reasonable measures to protect the information we hold. No system
    is perfectly secure.
  </p>
</Legal>
