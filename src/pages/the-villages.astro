---
// src/pages/the-villages.astro
// Hurricane Bath city page for The Villages. The conversion surface.
//
// Honors the locked Hurricane Bath v2.0 rules:
//  - breed_tier_pricing: smoothcoat / doublecoat tiers
//  - three_dog_cap: max 3 dogs, $20 decrement
//  - tiered_founders_rate: $55 smooth / $80 double, 12 months, ?founders=1
//  - founders_spots_remaining_counter: counter element ships here; JS that
//    queries bath_subscriptions lands in the chapter that creates the table
//  - cadence_4wk_or_2wk_same_price: 4wk default, 2wk freshness upgrade
//  - premium_inclusive_no_addons: one price per tier, no upsells
//  - specialist_named_not_promised: Paul named with photo placeholder
//  - villages_only_in_copy: this page is Villages-only, no other cities

import BaseLayout from '../layouts/BaseLayout.astro';

const apptSteps = [
  'We park in your driveway and set up the trailer.',
  'Your dog comes out. We bath in the climate controlled trailer.',
  'The Hurricane Bath does the work. Pressure dialed to the dog.',
  'High velocity dry in the same trailer. No standing wet.',
  'Your dog walks back inside, clean. We roll on.',
];

const reminders = [
  'Reminder three days before your appointment',
  'Reminder one day before',
  'Reminder the morning of',
  'Heads up text when we are on the way, with a live tracker',
];

const tiers = [
  {
    key: 'smooth',
    label: 'Smoothcoat',
    sub: 'Single coat, short hair. Labs, Boxers, Pointers, and friends.',
    recurring: 75,
    single: 95,
    founders: 55,
  },
  {
    key: 'double',
    label: 'Doublecoat',
    sub: 'Short or medium double coat that sheds without matting.',
    recurring: 100,
    single: 120,
    founders: 80,
  },
];
---

<BaseLayout
  title="The Villages, FL | Dog Gone Clean Hurricane Bath"
  description="Hurricane Bath service in The Villages, Florida. Powerful, gentle, in your driveway. Recurring every four weeks (or every two), or one off."
>

  <!-- HERO -->
  <section class="city-hero">
    <div class="glow glow-a"></div>
    <div class="glow glow-b"></div>
    <div class="container">
      <div class="city-hero__inner">
        <span class="city-hero__tag">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          The Villages, Florida
        </span>
        <h1>The Hurricane Bath,<br /><span class="grad">in your driveway.</span></h1>
        <p class="city-hero__sub">
          Mobile dog baths for The Villages, on a schedule you keep.
          Recurring every four weeks (or every two), or one off.
        </p>
        <a class="button button--primary button--lg" href="/book?founders=1">
          Lock in the founders rate
        </a>
      </div>
    </div>
  </section>

  <!-- FOUNDERS LAUNCH CARD -->
  <section class="section">
    <div class="container">
      <div class="launch-card">
        <div class="launch-card__eyebrow">
          <span class="launch-card__dot" aria-hidden="true"></span>
          The Villages launch pricing
        </div>

        <h2 class="launch-card__headline">Founders rate, locked for 12 months.</h2>
        <p class="launch-card__sub">
          You are early. This rate is reserved for the first households on
          the route. After 12 months, your rate moves to the then current
          recurring price.
        </p>

        <div class="launch-card__tiers">
          {tiers.map(t => (
            <div class="launch-tier">
              <div class="launch-tier__label">{t.label}</div>
              <div class="launch-tier__price">
                <span class="launch-tier__dollar">$</span>
                <span class="launch-tier__num">{t.founders}</span>
              </div>
              <div class="launch-tier__per">per visit, founders rate</div>
            </div>
          ))}
        </div>

        <!-- founders_spots_remaining_counter: hidden until the JS that reads
             from bath_subscriptions lands (same chapter that creates the table). -->
        <div id="launch-spot-count" class="launch-card__spots" hidden></div>

        <hr class="launch-card__divider" />

        <p class="launch-card__terms">
          One price per tier. No add ons. No surprise charges. Card on file
          at signup. Cancel any time, in two taps from your portal.
        </p>

        <a href="/book?founders=1" class="launch-card__cta">
          Claim my founders rate
          <span class="launch-card__arrow">&rsaquo;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- REGULAR PRICING -->
  <section class="section pricing-section" id="pricing">
    <div class="container">
      <div class="text-center">
        <p class="section-label">Standard pricing</p>
        <h2 class="section-title">Simple, two tiers, one price each.</h2>
        <p class="section-subtitle section-subtitle--center">
          Cycle time depends on coat type, so the price does too. Beyond
          that, no add ons, no upsells. The price you see is the price
          you pay.
        </p>
      </div>

      <div class="pricing-grid">
        {tiers.map(t => (
          <article class="pricing-card">
            <div class="pricing-card__type">{t.label}</div>
            <p class="pricing-card__sub">{t.sub}</p>
            <div class="pricing-card__rows">
              <div class="pricing-row">
                <div class="pricing-row__label">Recurring (every 4 or 2 weeks)</div>
                <div class="pricing-row__price">${t.recurring}</div>
              </div>
              <div class="pricing-row">
                <div class="pricing-row__label">Single visit</div>
                <div class="pricing-row__price">${t.single}</div>
              </div>
            </div>
          </article>
        ))}
      </div>

      <p class="pricing-fineprint">
        Up to three dogs per visit. Each additional dog is $20 less than
        the prior dog in the same tier. Mixed breeds route through a quick
        eligibility check at booking. Inside the 24 hour mark before your
        visit, the card on file is charged and the appointment is locked.
      </p>
    </div>
  </section>

  <!-- ELIGIBILITY -->
  <section class="section eligibility-section">
    <div class="container">
      <div class="text-center">
        <p class="section-label">Eligibility</p>
        <h2 class="section-title">What we bath, and what we do not.</h2>
        <p class="section-subtitle section-subtitle--center">
          The Hurricane Bath is built for dogs that do not need a haircut.
          We bath dogs whose coats clean up fast and dry well.
        </p>
      </div>

      <div class="elig-grid">
        <div class="elig-card elig-card--yes">
          <div class="elig-card__head">We bath</div>
          <ul>
            <li>Smoothcoat dogs (single short coats: Labs, Pointers, Boxers, and friends)</li>
            <li>Doublecoat dogs that shed without matting (short or medium double coats)</li>
            <li>Friendly dogs handleable without aggression</li>
            <li>Dogs at private homes inside The Villages with driveway parking</li>
          </ul>
        </div>
        <div class="elig-card elig-card--no">
          <div class="elig-card__head">We do not bath</div>
          <ul>
            <li>Dogs that need haircuts (we are bath only)</li>
            <li>Coats that mat or pack heavy undercoat against the skin</li>
            <li>Dogs that show aggression toward people</li>
            <li>Households outside the Villages service area</li>
          </ul>
        </div>
      </div>
      <p class="elig-note">
        Not sure your dog fits? The booking flow has a quick eligibility
        check. If a coat type is borderline, we will tell you up front,
        not at the door.
      </p>
    </div>
  </section>

  <!-- HOW THE APPOINTMENT WORKS -->
  <section class="section">
    <div class="container">
      <div class="text-center">
        <p class="section-label">What to expect</p>
        <h2 class="section-title">How a visit unfolds.</h2>
      </div>
      <ol class="appt-list">
        {apptSteps.map((step, i) => (
          <li>
            <span class="appt-num">{i + 1}</span>
            <span class="appt-text">{step}</span>
          </li>
        ))}
      </ol>
      <p class="appt-note">
        The whole visit fits inside a single block (we book in blocks,
        not arrival windows). The work runs inside the block; we do not
        promise an exact arrival minute.
      </p>
    </div>
  </section>

  <!-- SPECIALIST -->
  <section class="section specialist-section">
    <div class="container">
      <div class="text-center">
        <p class="section-label">Your specialist</p>
        <h2 class="section-title">Who runs your route.</h2>
      </div>
      <div class="specialist-card">
        <div class="specialist-card__avatar" aria-hidden="true">P</div>
        <div class="specialist-card__info">
          <h3>Paul Nickerson</h3>
          <p class="specialist-card__role">Owner and Hurricane Bath operator, The Villages</p>
          <p>
            Paul built the Hurricane Bath himself after years with the
            commercial systems showed him what to keep and what to fix.
            Today he runs the Villages route personally.
          </p>
          <p>
            The standard does not belong to a person. It belongs to the
            process. Every bath follows the same steps: dial down to soak,
            up to drive water to the skin, recirculate, flush if filthy,
            finish on the clean tank, dry in the climate controlled
            trailer. As Dog Gone Clean grows, every operator who joins
            the route is trained on the same standard. You will always
            know, by name and face, who is coming to your driveway.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- COMMUNICATION -->
  <section class="section">
    <div class="container">
      <div class="text-center">
        <p class="section-label">Communication</p>
        <h2 class="section-title">You will know we are coming.</h2>
      </div>
      <ul class="reminders-list">
        {reminders.map(text => (
          <li>
            <span class="reminders-dot" aria-hidden="true"></span>
            <span>{text}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section final-cta">
    <div class="container">
      <h2>Ready to stop thinking about the bath?</h2>
      <p>
        Lock in the founders rate while spots last. Card on file at
        signup, charged the day before your visit, never sooner. Cancel
        any time in two taps from your portal.
      </p>
      <a class="button button--ghost button--lg" href="/book?founders=1">
        Claim my founders rate
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  /* HERO */
  .city-hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-4xl) var(--space-2xl);
  }
  .city-hero .glow-a {
    top: -100px;
    right: -60px;
    width: 360px;
    height: 360px;
  }
  .city-hero .glow-b {
    top: 220px;
    left: -100px;
    width: 320px;
    height: 320px;
  }
  .city-hero__inner {
    max-width: 720px;
    margin-inline: auto;
    text-align: center;
  }
  .city-hero__tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: var(--radius-full);
    background: rgba(37, 99, 235, 0.08);
    color: var(--accent);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
  }
  .city-hero h1 {
    font-size: clamp(2.4rem, 6vw, 3.8rem);
    line-height: 1.06;
    margin-bottom: var(--space-lg);
  }
  .city-hero__sub {
    font-size: var(--text-lg);
    color: var(--soft);
    max-width: 540px;
    margin: 0 auto var(--space-xl);
  }

  /* LAUNCH CARD */
  .launch-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-top: 3px solid var(--accent);
    border-radius: var(--radius-lg);
    max-width: 640px;
    margin-inline: auto;
    padding: var(--space-2xl);
    box-shadow: var(--shadow-md);
  }
  .launch-card__eyebrow {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--space-lg);
  }
  .launch-card__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    animation: launch-pulse 2.4s ease-in-out infinite;
  }
  @keyframes launch-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.3; transform: scale(0.6); }
  }
  .launch-card__headline {
    font-size: clamp(1.4rem, 3vw, 1.75rem);
    margin: 0 0 var(--space-sm);
  }
  .launch-card__sub {
    font-size: var(--text-sm);
    color: var(--soft);
    margin: 0 0 var(--space-xl);
  }
  .launch-card__tiers {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }
  @media (max-width: 540px) {
    .launch-card__tiers { grid-template-columns: 1fr; }
  }
  .launch-tier {
    background: var(--surface-alt);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    text-align: center;
  }
  .launch-tier__label {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: var(--space-sm);
  }
  .launch-tier__price {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 2px;
    margin-bottom: var(--space-xs);
  }
  .launch-tier__dollar {
    font-size: 1.2rem;
    color: var(--muted);
  }
  .launch-tier__num {
    font-size: 3rem;
    font-weight: 800;
    color: var(--ink);
    line-height: 1;
    background: linear-gradient(100deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .launch-tier__per {
    font-size: var(--text-xs);
    color: var(--muted);
  }
  .launch-card__spots {
    background: rgba(37, 99, 235, 0.08);
    color: var(--accent);
    border-radius: var(--radius-md);
    padding: var(--space-md);
    text-align: center;
    font-size: var(--text-sm);
    font-weight: 700;
    margin-bottom: var(--space-lg);
  }
  .launch-card__divider {
    border: none;
    border-top: 1px solid var(--line);
    margin: 0 0 var(--space-lg);
  }
  .launch-card__terms {
    font-size: var(--text-sm);
    color: var(--soft);
    margin-bottom: var(--space-xl);
  }
  .launch-card__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 1rem var(--space-xl);
    background: linear-gradient(100deg, var(--accent), var(--accent2));
    color: #fff;
    border-radius: var(--radius-md);
    font-weight: 700;
    text-decoration: none;
    transition: gap var(--transition-base), box-shadow var(--transition-fast), transform var(--transition-fast);
    box-shadow: var(--shadow-cta);
  }
  .launch-card__cta:hover {
    color: #fff;
    gap: 12px;
    transform: translateY(-1px);
    box-shadow: 0 14px 36px rgba(37, 99, 235, 0.5);
  }
  .launch-card__arrow { font-size: 1.2em; line-height: 1; }

  /* PRICING */
  .pricing-section {
    background: var(--surface-alt);
    border-block: 1px solid var(--line);
  }
  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    max-width: 760px;
    margin: var(--space-2xl) auto 0;
  }
  @media (max-width: 700px) {
    .pricing-grid { grid-template-columns: 1fr; }
  }
  .pricing-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    box-shadow: var(--shadow-sm);
  }
  .pricing-card__type {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent2);
    margin-bottom: var(--space-sm);
  }
  .pricing-card__sub {
    font-size: var(--text-sm);
    color: var(--soft);
    margin: 0 0 var(--space-lg);
  }
  .pricing-card__rows {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .pricing-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-top: 1px solid var(--line);
    padding-top: var(--space-md);
  }
  .pricing-row__label {
    font-size: var(--text-sm);
    color: var(--ink);
  }
  .pricing-row__price {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--accent);
  }
  .pricing-fineprint {
    max-width: 720px;
    margin: var(--space-xl) auto 0;
    text-align: center;
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.7;
  }

  /* ELIGIBILITY */
  .elig-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    max-width: 760px;
    margin: var(--space-2xl) auto 0;
  }
  @media (max-width: 700px) {
    .elig-grid { grid-template-columns: 1fr; }
  }
  .elig-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    box-shadow: var(--shadow-sm);
  }
  .elig-card--yes { border-top: 3px solid var(--accent); }
  .elig-card--no { border-top: 3px solid #94a3b8; }
  .elig-card__head {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--space-md);
  }
  .elig-card--no .elig-card__head { color: var(--muted); }
  .elig-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .elig-card li {
    color: var(--soft);
    padding-left: 1.5rem;
    position: relative;
  }
  .elig-card--yes li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 8px;
    height: 8px;
    background: var(--accent2);
    border-radius: 50%;
  }
  .elig-card--no li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 10px;
    height: 2px;
    background: var(--muted);
    border-radius: 2px;
  }
  .elig-note {
    max-width: 640px;
    margin: var(--space-xl) auto 0;
    text-align: center;
    font-size: var(--text-sm);
    color: var(--soft);
  }

  /* APPOINTMENT STEPS */
  .appt-list {
    list-style: none;
    padding: 0;
    margin: var(--space-2xl) auto 0;
    max-width: 640px;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .appt-list li {
    display: flex;
    gap: var(--space-md);
    align-items: center;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-md) var(--space-lg);
    box-shadow: var(--shadow-sm);
  }
  .appt-num {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: #fff;
    border-radius: var(--radius-full);
    font-weight: 800;
  }
  .appt-text { color: var(--ink); }
  .appt-note {
    max-width: 640px;
    margin: var(--space-lg) auto 0;
    text-align: center;
    font-size: var(--text-sm);
    color: var(--muted);
  }

  /* SPECIALIST */
  .specialist-section {
    background: var(--surface-alt);
    border-block: 1px solid var(--line);
  }
  .specialist-card {
    max-width: 720px;
    margin: var(--space-2xl) auto 0;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-xl);
    padding: var(--space-2xl);
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    align-items: start;
  }
  @media (max-width: 640px) {
    .specialist-card { grid-template-columns: 1fr; text-align: center; }
  }
  .specialist-card__avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: #fff;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    margin: 0 auto;
    box-shadow: var(--shadow-md);
  }
  .specialist-card__info h3 {
    color: var(--accent);
    margin: 0 0 4px;
    font-size: var(--text-2xl);
  }
  .specialist-card__role {
    font-size: var(--text-sm);
    color: var(--accent2);
    font-weight: 700;
    margin: 0 0 var(--space-md);
  }
  .specialist-card__info p {
    color: var(--soft);
    margin-bottom: var(--space-sm);
  }
  .specialist-card__info p:last-child { margin-bottom: 0; }

  /* REMINDERS */
  .reminders-list {
    list-style: none;
    padding: 0;
    margin: var(--space-2xl) auto 0;
    max-width: 540px;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .reminders-list li {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    color: var(--ink);
  }
  .reminders-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent2);
    flex-shrink: 0;
  }

  /* FINAL CTA */
  .final-cta {
    background: linear-gradient(135deg, var(--ink), #15233f 60%, #0e2a3a);
    color: #fff;
    text-align: center;
  }
  .final-cta h2 {
    color: #fff;
    margin-bottom: var(--space-md);
  }
  .final-cta p {
    color: rgba(255, 255, 255, 0.78);
    max-width: 520px;
    margin: 0 auto var(--space-xl);
  }
  .final-cta .button--ghost {
    background: #fff;
    color: var(--ink);
  }
  .final-cta .button--ghost:hover {
    background: var(--bg);
    color: var(--ink);
