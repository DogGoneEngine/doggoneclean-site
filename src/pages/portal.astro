---
// src/pages/portal.astro
// Mounts the Dog Gone Clean client portal as a React island.
// Auth shell + empty state ships now; deep views (dashboard, pack,
// payments, reschedule, skip, cancel) arrive in subsequent slices.

import BaseLayout from '../layouts/BaseLayout.astro';
import PortalApp from '../components/portal/PortalApp.jsx';
---

<BaseLayout
  title="Client portal | Dog Gone Clean"
  description="Manage your Hurricane Bath subscription in The Villages, Florida."
  noIndex={true}
>
  <PortalApp client:load />
</BaseLayout>
