---
// src/pages/sms.astro
// Mirrors the Dog Gone Nails SMS terms structure, adapted to Clean's context:
// dog grooming (not nails), Clean's domain, and Clean's contact email.
import Legal from '../layouts/Legal.astro';
---

<Legal title="SMS Terms" updatedAt="June 2026" description="How Dog Gone Clean uses SMS notifications.">
  <h2>Program Description</h2>
  <p>
    Dog Gone Clean is a mobile dog grooming service. We send text messages to
    clients about their appointments and account.
  </p>

  <h2>Consent</h2>
  <p>
    Consent is obtained at booking on doggoneclean.us via a checkbox that is
    not pre-checked. Consent can also be managed from the client portal.
  </p>

  <h2>Message Categories</h2>
  <p>
    Messages include appointment confirmations, reminders, status updates, and
    account-related alerts. Optional marketing messages require explicit opt-in.
  </p>

  <h2>Message Frequency</h2>
  <p>
    Message frequency varies depending on your bookings and account preferences.
  </p>

  <h2>STOP and HELP Instructions</h2>
  <p>
    Reply <strong>STOP</strong> at any time to unsubscribe from all text messages.
    After you send STOP, we will send a confirmation that you have been
    unsubscribed. Reply <strong>HELP</strong> for help, or contact us directly
    at <a href="mailto:service@doggoneclean.us">service@doggoneclean.us</a>.
  </p>

  <h2>Carrier Disclaimer</h2>
  <p>
    Message and data rates may apply. Carriers are not liable for delayed or
    undelivered messages.
  </p>

  <h2>Privacy &amp; Third-Party Disclosure</h2>
  <p>
    Mobile phone numbers, SMS consent, and text message content are never shared
    with third parties or affiliates for marketing purposes. For more details,
    see our <a href="/privacy">Privacy Policy</a>.
  </p>
</Legal>
