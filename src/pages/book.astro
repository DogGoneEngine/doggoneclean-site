---
// src/pages/book.astro
// The Hurricane Bath signup funnel, mounted as a React island. Sign-in
// gates entry (the data model ties every row to an auth user); the flow
// then runs place -> dogs -> plan -> real slot picker -> review. The
// card-on-file step opens with the Stripe SetupIntent slice; until then
// the funnel does not fake a card form. Built against real services from
// the first commit (no_mockups): live city pricing, real open slots from
// bath_open_slots, and the bath_start_subscription RPC.

import BaseLayout from '../layouts/BaseLayout.astro';
import BookingApp from '../components/portal/BookingApp.jsx';
---

<BaseLayout
  title="Book the Hurricane Bath | Dog Gone Clean"
  description="Sign up for the Hurricane Bath in The Villages, Florida. Pick your cadence, pick a time, lock in the founders rate."
  noIndex={true}
>
  <BookingApp client:load />
</BaseLayout>
