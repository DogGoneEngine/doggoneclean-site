---
// src/pages/book.astro
// The Hurricane Bath signup funnel, mounted as a React island. Sign-in
// gates entry (the data model ties every row to an auth user); the flow
// then runs place -> dogs -> plan -> real slot picker -> review. The
// card-on-file step opens with the Stripe SetupIntent slice; until then
// the funnel does not fake a card form. Built against real services from
// the first commit (no_mockups): live city pricing, real open slots from
// bath_open_slots, and the bath_start_subscription RPC.
//
// BOOKING_OPEN gate (jake_takes_new_v2_clients): new-client online booking is
// closed until the Dog Gone Clean Stripe account is live and Jake is taking new
// v2.0 clients. While it is closed, /book shows an honest "at capacity, get on
// the list" waitlist instead of the signup funnel, so a new client who cannot
// pay yet is never sent into a card step that cannot complete. The funnel below
// is untouched: flip BOOKING_OPEN to true the day Stripe is wired and tested and
// the live funnel returns with no other change. The waitlist writes to the same
// `waitlist` table the Ocala page uses, and becomes Jake's opening book.

import BaseLayout from '../layouts/BaseLayout.astro';
import BookingApp from '../components/portal/BookingApp.jsx';

const BOOKING_OPEN = false;
---

{BOOKING_OPEN ? (
  <BaseLayout
    title="Book the Hurricane Bath | Dog Gone Clean"
    description="Sign up for the Hurricane Bath in The Villages, Florida. Pick your cadence, pick a time, lock in the founders rate."
    noIndex={true}
  >
    <BookingApp client:load />
  </BaseLayout>
) : (
  <BaseLayout
    title="Get on the list | Dog Gone Clean"
    description="Full for 20 years, and a rare round of brand-new seats is opening. Get on the list and be first in line the second a spot opens."
    noIndex={true}
  >
    <section class="wl">
      <div class="wl__glow"></div>
      <div class="container">
        <div class="wl__inner">
          <span class="wl__tag">A rare opening</span>
          <h1 class="wl__title">We're full.<br /><span class="grad">You're early.</span></h1>
          <p class="wl__lede">
            For over 20 years the book has been full and stayed full. Right now,
            for a short window, we are opening up a fresh round of brand-new seats.
            This list is how you get one. Get on it and you are first in line,
            ahead of everyone, the second a seat opens. These go fast. Being
            early is the whole game.
          </p>
          <p class="wl__sub">
            Already a client? <a href="/portal">Your portal is ready.</a>
          </p>

          <div class="wl__card">
            <form id="waitlist-form" class="wl__form" novalidate>
              <div class="wl__field">
                <label class="wl__label" for="wl-email">Your email address</label>
                <input class="wl__input" id="wl-email" name="email" type="email" autocomplete="email" required inputmode="email" placeholder="you@example.com" />
              </div>

              <div class="wl__field">
                <label class="wl__label" for="wl-city">Where are you?</label>
                <select class="wl__input" id="wl-city" name="city_slug" required>
                  <option value="the-villages">The Villages, FL</option>
                  <option value="ocala">Ocala, FL</option>
                </select>
              </div>

              <div class="wl__field">
                <label class="wl__label" for="wl-zip">ZIP code (optional)</label>
                <input class="wl__input" id="wl-zip" name="zip_code" type="text" autocomplete="postal-code" inputmode="numeric" maxlength="10" />
              </div>

              <div class="wl__field">
                <label class="wl__label" for="wl-dogs">How many dogs? (optional)</label>
                <select class="wl__input" id="wl-dogs" name="dog_count">
                  <option value="">Select</option>
                  <option value="1">1 dog</option>
                  <option value="2">2 dogs</option>
                  <option value="3">3 dogs</option>
                  <option value="4">4 or more</option>
                </select>
              </div>

              <button type="submit" class="button button--primary button--lg button--block">Get me in line</button>
              <p class="wl__note" id="wl-msg" hidden></p>
              <p class="wl__fine">First on the list, first into the new seats.</p>
            </form>
          </div>
        </div>
      </div>
    </section>
  </BaseLayout>
)}

<style>
  .wl {
    position: relative;
    padding: var(--space-5xl) 0 var(--space-4xl);
    overflow: hidden;
    text-align: center;
  }
  .wl__glow {
    position: absolute;
    inset: -20% 0 auto 0;
    height: 60%;
    background:
      radial-gradient(60% 80% at 25% 0%, rgba(56, 132, 255, 0.18), transparent 70%),
      radial-gradient(50% 70% at 85% 15%, rgba(120, 80, 255, 0.13), transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .wl__inner { position: relative; z-index: 1; max-width: 40rem; margin: 0 auto; }
  .wl__tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent, #2563eb);
    margin-bottom: var(--space-sm);
  }
  .wl__title {
    font-size: clamp(2.2rem, 7vw, 3.8rem);
    line-height: 1.07;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-lg);
  }
  .wl__lede {
    max-width: 34rem;
    margin: 0 auto var(--space-md);
    font-size: var(--text-lg);
    color: var(--color-text-secondary, #475569);
    line-height: 1.7;
  }
  .wl__sub {
    margin: 0 auto var(--space-2xl);
    font-size: var(--text-base);
    color: #64748b;
  }
  .wl__card {
    max-width: 460px;
    margin: 0 auto;
    background: var(--card, #fff);
    border: 1px solid var(--line, #e3e8f4);
    border-radius: var(--radius-lg, 18px);
    padding: var(--space-2xl);
    box-shadow: 0 8px 32px rgba(13, 30, 70, 0.10);
  }
  .wl__form { display: flex; flex-direction: column; gap: var(--space-md); text-align: left; }
  .wl__field { display: flex; flex-direction: column; gap: 6px; }
  .wl__label { font-size: var(--text-sm); font-weight: 600; color: #334155; }
  .wl__input {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid var(--line, #cbd5e8);
    border-radius: var(--radius-md, 12px);
    font-size: var(--text-base);
    font-family: inherit;
    background: #fff;
  }
  .wl__input:focus { outline: 2px solid var(--accent, #2563eb); outline-offset: 1px; }
  .button--block { width: 100%; margin-top: var(--space-sm); }
  .wl__note { margin-top: var(--space-sm); text-align: center; font-size: var(--text-sm); padding: var(--space-md); border-radius: var(--radius-md, 12px); }
  .wl__note--success { background: rgba(37, 99, 235, 0.08); color: #1d4ed8; }
  .wl__note--error { background: rgba(180, 40, 40, 0.08); color: #b42828; }
  .wl__fine { margin-top: var(--space-sm); text-align: center; font-size: var(--text-xs); color: #94a3b8; }
</style>

<script>
  // Lead capture for the capacity waitlist. Writes to the same `waitlist` table
  // the Ocala page uses, through the public (RLS-locked, insert-only) anon key.
  const SUPABASE_URL = 'https://urebdrosrxejhubpbxsa.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_3y18WUvZCuW-fiuPywR6nw_BLQyx1h6';

  const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
  if (form) {
    // Prefill the area from ?city= when a city page sent them here.
    const params = new URLSearchParams(window.location.search);
    const city = params.get('city');
    const citySel = document.getElementById('wl-city') as HTMLSelectElement | null;
    if (city && citySel && Array.from(citySel.options).some((o) => o.value === city)) {
      citySel.value = city;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const msg = document.getElementById('wl-msg')!;
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      msg.hidden = false;
      msg.className = 'wl__note';
      msg.textContent = 'Adding you to the list...';
      submitBtn.disabled = true;

      const fd = new FormData(form);
      const dogVal = fd.get('dog_count') as string;
      const payload = {
        email: ((fd.get('email') as string) || '').trim().toLowerCase(),
        city_slug: (fd.get('city_slug') as string) || 'the-villages',
        zip_code: ((fd.get('zip_code') as string) || '').trim() || null,
        dog_count: dogVal ? parseInt(dogVal, 10) : null,
      };

      try {
        const res = await fetch(`${SUPABASE_URL}/rest/v1/waitlist`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            apikey: SUPABASE_KEY,
            Authorization: `Bearer ${SUPABASE_KEY}`,
            Prefer: 'return=minimal',
          },
          body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error(await res.text());
        msg.classList.add('wl__note--success');
        msg.textContent = "You're in, and near the front of the line. The second a new seat opens, you hear from us first.";
        form.reset();
      } catch {
        msg.classList.add('wl__note--error');
        msg.textContent = 'Something went wrong. Please try again in a moment.';
        submitBtn.disabled = false;
      }
    });
  }
</script>
