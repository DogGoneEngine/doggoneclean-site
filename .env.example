# Dog Gone Clean - environment template.
# Copy this to .env and fill in real values. NEVER commit .env (it is gitignored).
# Get these from the Supabase dashboard for project dgc-prod (ref urebdrosrxejhubpbxsa):
#   Project Settings -> API     for the URL and keys
#   Project Settings -> Database for the password

# Public Supabase config. Safe to ship to the browser; used by the Astro site and the
# client portal. Access is gated by row-level security, so the anon key alone reaches
# nothing until RLS policies and auth exist.
PUBLIC_SUPABASE_URL=https://urebdrosrxejhubpbxsa.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# Server-only. Bypasses row-level security, so it must NEVER reach the browser and never
# be committed. Used by server endpoints, build-time seeding, and admin scripts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres password for direct database access (Supabase CLI, psql, manual migrations).
# Not used by the app at runtime; the keys above are. Keep it out of the browser.
SUPABASE_DB_PASSWORD=your-db-password
