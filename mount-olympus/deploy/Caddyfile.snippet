# Mount Olympus - Caddy site block for mountolympusops.com
#
# This REPLACES whatever currently proxies mountolympusops.com to n8n
# (the old "reverse_proxy n8n:5678" block). It serves the static dashboard
# from a directory. Pick ONE gate below so only you can reach it.
#
# ============================================================
# GATE OPTION A (RECOMMENDED): Google login via Cloudflare Access
# ============================================================
# You log in with your Google account, restricted to your email only. No
# password to remember, nothing crawlable, and the origin is never exposed.
# Set this up in the Cloudflare dashboard (Zero Trust > Access > Applications):
#   - Application: mountolympusops.com
#   - Policy: Allow, Include > Emails > your Google address
# Cloudflare's free Zero Trust tier covers this (up to 50 users).
#
# Then lock the droplet so it ONLY answers Cloudflare (so nobody can skip the
# Google gate by hitting the server IP directly). With Option A, use this block:
#
# mountolympusops.com {
# 	@notcloudflare not remote_ip 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22
# 	respond @notcloudflare 403
# 	root * /srv/mountolympus
# 	encode gzip zstd
# 	file_server
# 	header {
# 		X-Robots-Tag "noindex, nofollow"
# 		X-Frame-Options "DENY"
# 		Referrer-Policy "no-referrer"
# 	}
# }
#
# (Even cleaner, zero open ports: a Cloudflare Tunnel with cloudflared on the
# droplet, same Access policy. Ask Claude to set that up if you want it.)
#
# ============================================================
# GATE OPTION B (fallback, no Cloudflare): a password prompt
# ============================================================
# A plain username/password at the edge. Private and uncrawlable, but it is a
# password, not Google. Generate the hash with:
#   docker exec engine-caddy-1 caddy hash-password --plaintext 'YOUR_PASSWORD'
#
mountolympusops.com {
	root * /srv/mountolympus
	encode gzip zstd
	file_server

	basic_auth {
		paul $2a$14$REPLACE_WITH_REAL_HASH
	}

	header {
		X-Robots-Tag "noindex, nofollow"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
	}
}

# Either way: delete the old vault.mountolympusops.com block; it is unused.
